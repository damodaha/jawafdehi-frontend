    <script id="__REACT_QUERY_STATE__" type="application/json">{"mutations":[],"queries":[{"dehydratedAt":1781094635563,"state":{"data":{"published_cases":28,"cases_under_investigation":2885,"cases_closed":6,"entities_tracked":2998,"last_updated":"2026-06-10T12:28:55.716850+00:00"},"dataUpdateCount":1,"dataUpdatedAt":1781094634813,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["statistics"],"queryHash":"[\"statistics\"]"},{"dehydratedAt":1781094635563,"state":{"data":{"count":28,"next":"https://portal.jawafdehi.org/api/cases/?page=2","previous":null,"results":[{"id":443,"case_id":"case-99ca8d124afa","slug":"case-99ca8d124afa-dbd7c3","case_type":"CORRUPTION","state":"PUBLISHED","title":"काठमाडौँ महानगरपालिका तत्कालीन इन्जिनियर (उपनिर्देशक) रामबाबु महतो कोईरी उपर गैरकानूनी सम्पत्ति आर्जन भ्रष्टाचार मुद्दा (081-CR-0116)","short_description":"विशेष अदालतमा नेपाल सरकारको वादमा माला कुमारी महतो र रामबाबु महतो कोइरी विरुद्ध दर्ता भएको भ्रष्टाचार (गैरकानूनी सम्पत्ति आर्जन) मुद्दा। दर्ता मिति: २०८२/०२/२६। हाल चलिरहेको।","thumbnail_url":"https://gorkhapatraonline.com/storage/media/279488/ciaa.jpg","banner_url":"https://gorkhapatraonline.com/storage/media/279488/ciaa.jpg","case_start_date":"2025-06-09","case_end_date":null,"entities":[{"id":2430,"nes_id":null,"display_name":"काठमाडौं","type":"location","notes":""},{"id":3650,"nes_id":"entity:person/mala-kumari-mahato","display_name":"माला कुमारी महतो","type":"accused","notes":"मुख्य प्रतिवादीको श्रीमती, सम्पत्ति जफत गर्ने प्रयोजनार्थ प्रतिवादी"},{"id":3649,"nes_id":"entity:person/rambabu-mahato-koiri","display_name":"रामबाबु महतो कोइरी","type":"accused","notes":"काठमाडौँ महानगरपालिकाका तत्कालीन इन्जिनियर (उपनिर्देशक), मुख्य प्रतिवादी"}],"tags":["Illegal Enrichment","Civil Servant","Corruption"],"description":"**क) अभियोगदावीको सार**\r\n\r\nप्रस्तुत मुद्दामा जिल्ला धनुषा, क्षीरेश्वरनाथ नगरपालिका वडा नं. ५ (साविक नकटाझिज-६) स्थायी वतन भई हाल जिल्ला काठमाडौं, काठमाडौं महानगरपालिका वडा नं. ४ चण्डोल बस्ने रामबाबु महतो भन्ने रामबाबु महतो कोइरीले पदीय मर्यादा विपरीतका कार्यहरू गरी गैरकानूनी रुपमा सम्पत्ति आर्जन गरी भ्रष्टाचार गरेको भन्ने विषयमा अनुसन्धान हुँदा निज रामबाबु महतोले काठमाडौँ महानगरपालिकाको कार्यालय, काठमाडौँमा सार्वजनिक पदधारण गरेको मिति २०४६/०१/१९ गतेदेखि मिति २०७८/११/३० गते सम्मको जाँच अवधिमा निज प्रतिवादी समेतको अनुसन्धानको क्रममा सङ्कलित विभिन्न बैङ्क तथा वित्तीय संस्थाहरु एवम् सहकारी संस्थाहरुबाट प्राप्त बैंक खाताको विवरण (Bank Statement), चेक भौचर लगायतका विवरणहरु, एभरेष्ट बैंक लिमिटेडबाट प्राप्त धितो मूल्यांकन प्रतिवेदन, भूमिसुधार तथा मालपोत कार्यालय, डिल्लीबजार, काठमाडौं र जनकपुरधाम, धनुषा, मालपोत कार्यालय, चाबहिल, काठमाडौंबाट प्राप्त जग्गा खरिद सम्बन्धी राजीनामा लिखत पारितका कागजातहरु, भूमिसुधार तथा मालपोत कार्यालय, जनकपुरधाम, धनुषाको अंशबण्डा पत्र, क्षीरेश्वरनाथ नगरपालिका वडा नं. ७ को घरबाटो सिफारिस पत्र, यातायात व्यवस्था कार्यालयबाट प्राप्त पत्र, कम्पनी रजिष्ट्रारको कार्यालय, त्रिपुरेश्वरबाट प्राप्त पत्र, आन्तरिक राजस्व कार्यालय, टंगालबाट प्राप्त पत्र र कागजात, त्रियोग बचत तथा ऋण सहकारी संस्था लिमिटेड, मण्डिखाटार, काठमाडौंबाट प्राप्त पत्र, स्टेटमेन्ट, चेक भौचरहरू, ऋण आवेदन पत्र, काठमाडौं महानगरपालिकाको कार्यालय र मुख्यमन्त्री तथा मन्त्रिपरिषद्‌को कार्यालय, बागमती प्रदेशबाट प्राप्त सम्पत्ति विवरण फाराम, लिटिल एन्जल्स स्कूल, हात्तीवन, मल्पि सिटी स्कूल, नक्साल, मल्पि इन्टरनेशनल कलेज, बालुबाटार, द चाँदबाग स्कूल, बाँसबारी, पेन्टागन उ.मा.वि. तीनकुने. वालुवाटार स्कूल, काठमाडौँ, नाइटिङ्गेल स्कूल, कुपण्डोलबाट प्राप्त अध्ययन शुल्क खुल्ने पत्र र कागजातहरू, बीमा समिति र यूनियन लाइफ इन्स्योरेन्स लगायतका विभिन्न बीमा कम्पनीबाट प्राप्त पत्र, प्रतिवादीहरूका साथै जग्गा बिक्रेताहरु, वडा सचिव र जग्गाको कारोबारसँग सम्बन्धित व्यक्तिहरूको बयान/घटना विवरण कागज लगायत प्रतिवादी रामबाबु महतोले अनुसन्धानको क्रममा पेस गरेका कागजात सहितका आधार प्रमाणहरुलाई समष्टिगत रुपमा विश्लेषण गरी हेर्दा प्रतिवादी रामबाबु महतो भन्ने रामबाबु महतो कोईरीको आयको तुलनामा व्यय अमिल्दो देखिएको, मनासिब कारणविना अमिल्दो र अस्वाभाविक उच्च जीवनस्तर यापन गरेको पुष्टि भएकोमा उक्त सम्पत्ति के कस्तो श्रोतबाट आर्जन गरेको हो भन्ने कुरा प्रतिवादी रामबाबु महतो भन्ने रामबाबु महतो कोईरीले शङ्कारहित तवरबाट प्रमाणित गर्न नसकेको कारणबाट निज प्रतिवादी रामवावु महतो भन्ने रामबाबु महतो कोईरीले गैरकानूनीरुपमा सम्पत्ति आर्जन गरेको समेतको कसूरजन्य कार्य गरेको वारदात स्थापित भएको सार अख्तियारले निकालेको थियो।\r\n\r\nअनुसन्धानको जाँच अवधिको आय-व्ययहरुको गणना गरी अनुसन्धान गर्दा जाँच अवधिमा सिर्जित सम्पत्ति एवं खर्च तथा लगानीहरुमा गरिएको कूल खर्च र सोही अवधिको आयहरुको आय-व्यय प्रवाह विवरण (Income Expenditure Flow Chart) अनुसार जाँच अवधिमा स्रोत खुल्न आए बमोजिम प्रतिवादी रामबाबु महतोको वैध आय रु.३,३७,७९,४००।३४ (तीन करोड सैंतीस लाख उनासी हजार चार सय रुपैयाँ चौतीस पैसा) को अनुपातमा सोही अवधिमा प्रतिवादी रामबावु महतोले सिर्जना गरेका सम्पत्ति एवं खर्च तथा लगानी रु.७,९६,७६,८०४।२३ (सात करोड छयानब्बे लाख छयहत्तर हजार आठ सय चार रुपैयाँ तेइस पैसा) देखिन आएबाट निज प्रतिवादी रामबाबु महतोको अनुसन्धान अवधिको कूल आयआर्जन रु.३,३७,७९,४००।३४ (तीन करोड सैंतीस लाख उनासी हजार चार सय रुपैयाँ चौतीस पैसा मा निजले गरेको कूल खर्च तथा लगानी (व्यय) रु.७,९६,७६,८०४।२३ (सात करोड छयानब्बे लाख छयहत्तर हजार आठ सय चार रुपैयाँ तेइस पैसा) घटाउँदा हुन आउने रु.४,५८,९७,४०३। ८८ (चार करोड अन्ठाउन्न लाख सन्तानब्बे हजार चार सय तीन रुपैयाँ अठासी पैसा) ले कूल आयभन्दा कुल व्यय अधिक हुन गई सोही बराबरको सम्पत्तिको स्रोत पुष्टि गर्न नसकेको हुँदा निजले सार्वजनिक सेवाको पदमा बहाल रहँदा आफ्नो पदीय हैसियतको दुरुपयोग गरी गैरकानूनी सम्पत्ति आर्जन गरी अमिल्दो र अस्वाभाविक उच्च जीवनस्तर यापन गरेको पुष्टि हुन आएकोले निज रामबाबु महतोको उक्त कार्य भ्रष्टाचार निवारण ऐन, २०५९ को दफा २० को उपदफा (१) मा परिभाषित एवं निषेधित गरिएबमोजिमको कसुर गरेको पुष्टि भएको हुँदा निजलाई विगो रु.४,५८,९७,४०३। ८८ (चार करोड अन्ठाउन्न लाख सन्तानब्बे हजार चार सय तीन रुपैयाँ अठासी पैसा) कायम गरी भ्रष्टाचार निवारण ऐन, २०५९ को दफा २० को उपदफा (२) बमोजिम बिगो अनुसार कैद र विगो बमोजिम जरिवाना हुनका साथै भ्रष्टाचार निवारण ऐन, २०५९ को दफा ४७ तथा अख्तियार दुरूपयोग अनुसन्धान आयोग ऐन, २०४८ को दफा २९ख बमोजिम गैरकानूनी रूपमा आर्जन गरेको सम्पत्ति जफत गरी पाउन र निजले यस आयोग समक्ष पेस गरेको सम्पत्ति विवरणमा वास्तविक सम्पत्तिको विवरण उल्लेख नगरी सम्पत्ति लुकाई छिपाई झुट्टा विवरण पेस गरेको पुष्टि भएकोले भ्रष्टाचार निवारण ऐन, २०५९ को दफा १६ को उपदफा (२) बमोजिमको कसुरमा भ्रष्टाचार निवारण ऐन, २०५९ को दफा १६ को उपदफा (२) बमोजिम कैद र जरिवाना गरी यसरी लुकाई छिपाई राखिएको सम्पत्ति जफत हुन मागदाबी लिइएको छ।\r\n\r\nसाथै निज रामबाबु महतो सार्वजनिक सेवाको पदमा रहँदाका बखत अख्तियारको दुरुपयोग गरी गैरकानूनी रूपमा सम्पत्ति आर्जन गरेको स्रोत नखुल्ने सम्पत्तिबाट श्रीमती माला कुमारी महतोको नाममा जग्गा खरिद, शेयर खरिद, घर निर्माण र बैङ्क मौज्दात समेतको सम्पत्ति भ्रष्टाचार निवारण ऐन, २०५९ को दफा ४७तथा अख्तियार दुरूपयोग अनुसन्धान आयोग ऐन, २०४८ को दफा २९ख. समेतको प्रचलित कानून बमोजिम जफत गर्ने प्रयोजनार्थ मात्र निज माला कुमारी महतोलाई प्रतिवादी कायम गरिएको थियो। मिति २०८२।०२।२६ गते अख्तियार दुरुपयोग अनुसन्धान आयोगले विशेष अदालतमा माथिको अभियोगदावी लिई अभियोगपत्र दायर गरिएको थियो।\r\n\r\n**प्रतिवादी रामबाबु महतोको जाँच अवधिको आय-व्ययको समग्र अवस्था खुल्ने तालिका**\r\n\r\n| क्र.सं. | आय |  | ब्यय |  | कैफियत |\r\n| ------- | --- | --- | ---- | --- | ------ |\r\n| विवरण | रकम रु. | विवरण | रकम रु. |\r\n| १ | पारिश्रमिक बचत/तलब भत्ता | ५१,८७,४६५.५३ | जग्गा खरिद | ३,५३,७६,८३३.३३ |  |\r\n| २ | बैठक भत्ता | १,४८,७०५.०० | रजिष्ट्रेशन दस्तुर | ३,९७,५६६.६७ |  |\r\n| ३ | ग्रेड मिलान रकम | ८१,६०४.६० | घर निर्माण | ७९,२३,८४८.७९ |  |\r\n| ४ | सेवा पूर्वको आय | २१,७००.०० | ऋण तिरेको | ६७,२५,५६१.२८ |  |\r\n| ५ | अंशबण्डा बापत प्राप्त रकम | ५,००,०००.०० | त्रियोग बचत तथा सहकारीबाट लिएको ऋण तिरेको | ९२,१५,२३४.०० |  |\r\n| ६ | ऋण लिएको | १,२४,६८,०००.०० | सवारी साधन खरिद | २०,८४,०१०.०० |  |\r\n| ७ | त्रियोग बचत तथा सहकारीबाट ऋण लिएको | ८७,३१,१८३.०० | कन्सल्टेन्सी स्थापना तथा सञ्चालन खर्च | १९,५०,८२९.०० |  |\r\n| ८ | कन्सल्टेन्सीको आय | २१,४२,५८९.५० | बीमा शुल्क भुक्तानी | २६,९४,२६९.४४ |  |\r\n| ९ | घरबहाल आय | २,०६,२६०.०२ | शेयर खरिद (सहकारीको शेयर समेत) | १८,०५,१६५.०० |  |\r\n| १० | सवारी साधन बिक्री आय | ६,६२,३४०.०० | अध्ययन शुल्क१९७ | २२,५५,२००.१७ |  |\r\n| ११ | शेयर बिक्री | १८,९१०.०० | मुद्दती रकम जम्मा | ४०,००,०००.०० |  |\r\n| १२ | शेयर लाभांश | १,८४,६९७.०० | सामाजिक व्यवहार खर्च (छोरीको विवाह) | १०,००,०००.०० |  |\r\n| १३ | मुद्दती रकम फिर्ता | २१,७०,३७३.४२ | निजी प्रयोजनमा वैदेशिक भ्रमण खर्च | १,४०,०००.०० |  |\r\n| १४ | ब्याज आय (मुद्दती रकमको समेत) | १२,५५,५७२.२७ | सून/चाँदी खरिद | ३३,०००.०० |  |\r\n| १५ |  |  | बैंकमा रहेको अन्तिम मौज्दात | ४०,७५,२८६.५५ |  |\r\n| कूल जम्मा रु. |  | ३,३७,७९,४००.३४ |  | ७,९६,७६,८०४.२३ |  |\r\n| कूल ऋणात्मक रकम रु. |  | (४,५८,९७,४०३.८८) |  |  |  |\r\n\r\n**अनुसन्धान अनुरूप खुलेको विस्तृत तथ्य**\r\n\r\n**१. गैरकानूनी रूपमा सम्पत्ति आर्जन गरेको अभियोग**\r\n\r\nरामबाबु महतोले आफ्नो सार्वजनिक सेवाको अवधिमा आफ्नो र आफ्नो परिवारको नाममा वैधानिक आयस्रोतभन्दा बढी र अस्वाभाविक देखिने सम्पत्ति आर्जन गरेको मुख्य अभियोग छ।अनुसन्धान अवधि (आ.व. २०४५/४६ देखि २०७८/११/३० सम्म) मा उनको कुल आय भन्दा व्यय र लगानी धेरै देखिएकाले सो बराबरको सम्पत्तिको स्रोत नखुलेको दाबी गरिएको छ।\r\n\r\n**२. जग्गा खरीदमा वास्तविक मूल्य लुकाएको (राजश्व छली)**\r\n\r\nजग्गा खरीद गर्दा मालपोत कार्यालयको लिखतमा कम मूल्य (थैली अंक) राखेर वास्तविक कारोबार मूल्य लुकाई राजश्व छली गरेको अभियोग छ। काठमाडौं,बुढानिलकण्ठको जग्गा: बुढानिलकण्ठ वडा नं. ३ को कि.नं. ११४२ को जग्गा खरीद गर्दा वास्तविक कारोबार मूल्य रु. २,९९,२५०००/- (प्रति आना रु. ३६ लाख) भए तापनि रजिष्ट्रेशन लिखतमा रु.८२,५०,०००/- मात्र देखाई वास्तविक मूल्य लुकाएको पाइएको छ। धनुषा,हरिहरपुरको जग्गा: श्रीमती माला कुमारी महतोको नाममा धनुषाको हरिहरपुरमा जग्गा खरीद गर्दा वास्तविक मूल्य\\*\\*रु. ५२,२३,०००/-भए तापनि लिखतमा रु.२५,००,०००/- मात्र उल्लेख गरिएको थियो।\r\n\r\n**३. अवैध सम्पत्ति लुकाउन आफन्तको नाम प्रयोग गरेको**\r\n\r\nआफ्नो गैरकानूनी कमाइलाई लुकाउनका लागि रामबाबु महतोले आफ्ना श्रीमती, साढुभाइ (कृष्णप्रसाद मेहता) र साली (रीना कुशवाहा) को नाममा कारोबार गर्ने गरेको अभियोग छ।\r\n\r\n* बुढानिलकण्ठको जग्गा खरीद प्रक्रियामा साली रीना कुशवाहाको नाममा बैनापट्टा गरी आफ्नो अवैध लगानी लुकाउन खोजेको सप्रमाण पुष्टि भएको दाबी गरिएको छ।\r\n* विभिन्न सहकारीहरूमा समेत आफन्तको नाममा रकम राख्ने र अरूको नामबाट घरजग्गा खरीद गर्ने गरेको उजुरीमा उल्लेख छ।\r\n\r\n**४. झुटा विवरण र स्रोत नखुलेको लगानी**\r\n\r\n* रामबाबु महतोले अंशबण्डाबापत रु. ३०,००,०००/- प्राप्त गरेको दाबी गरे तापनि कागजात र प्रमाणबाट जम्मा रु.५,००,०००/- मात्र प्राप्त गरेको देखिएकाले उनले आफ्नो सम्पत्तिको स्रोत पुष्टि गर्न झुटा विवरण पेस गरेको आरोप छ।\r\n* बैंकबाट लिइएको कर्जा र अन्य खर्चहरूको तुलनामा उनको वैध आम्दानी न्यून देखिएकाले ती सबै लगानी भ्रष्टाचारजन्य कार्यबाट आर्जित भएको अभियोग पत्रको सार छ।\r\n\r\nयी अभियोगहरू पुष्टि गर्न अख्तियार दुरुपयोग अनुसन्धान आयोगले बैंक स्टेटमेन्ट, जग्गा धनीको बयान, जग्गाको मूल्यांकन प्रतिवेदन र मालपोत कार्यालयका कागजातहरूलाई मुख्य प्रमाणको रूपमा पेस गरेको छ।\r\n\r\n**ख) प्रतिवादी एवम् घटनासँग सम्बन्धित व्यक्तिहरुको तितम्बा बयानको सार**\r\n\r\n| क्र.सं. | बयानकर्ताको नाम | बयान मिति | बयानको सार |\r\n| ------- | --------------- | --------- | ---------- |\r\n| १ | माला कुमारी महतो रामबाबु महतोकी श्रीमती — तितम्बा बयान | २०८२ वैशाख २६ | धनुषा हरिहरपुर कि.नं. २६१५ र १६०१ को जग्गा आफूहरूले रु.५२ लाख २३ हजारमा नै खरिद गरेको, राजस्व छलने काम नगरेको भनिन्। बुढानीलकण्ठको कि.नं. ११४३ को जग्गा बहिनी रीना कुशवाहाले कतिमा किनेको आफूलाई थाहा नभएको बताइन्। एभरेष्ट बैंकको ऋण प्रस्तावपत्रमा बैंकले के लेखेको भन्ने जानकारी नभएको, लिखतमा छुटेको कारण थाहा नभएको उल्लेख गरिन्। |\r\n| २ | मनोज कुमार मिश्र तत्कालीन वडा सचिव, क्षीरेश्वरनाथ नगरपालिका वडा नं. ७ | २०८१ कार्तिक ०५ | मिति २०७२/१०/११ मा घरबाटो प्रमाणित सिफारिस पत्रमा आफ्नो दस्तखत रहेको स्वीकार गरे। जग्गाधनी सावित्री पोखरेलको निवेदन अनुसार कि.नं. १६०१ र २६१५ को जग्गामा फिल्डमा गई यकीन गरी सिफारिस गरिएको, तर सो मितिसम्म उक्त कित्तामा घर नभएको बताए। मालपोत कार्यालयले घर कसरी कायम गर्‍यो भन्ने आफूलाई थाहा नभएको जनाए। |\r\n| ३ | रीना कुशवाहा माला कुमारी महतोकी सहोदर बहिनी — प्रथम बयान | २०८२ वैशाख ०४ | रामबाबु महतोले त्रियोग सहकारीबाट जमानी बसेर रु.४० लाख ऋण उपलब्ध गराएको बताइन्। बुढानीलकण्ठ कि.नं. ११४३, क्षेत्रफल ०-८-१-१ को जग्गा मिति २०७८/०४/१० मा रु.२ करोड १७ लाख ५० हजारमा खरिद गरेको, जग्गाको रकम व्यवसायबाट आफ्नो तर्फबाट दिएको र जग्गा विक्रेतालाई रु.१ करोड नगद सेञ्चुरी बैंकमा जम्मा गरेको उल्लेख गरिन्। |\r\n| ४ | रीना कुशवाहा माला कुमारी महतोकी सहोदर बहिनी — तितम्बा बयान | २०८२ वैशाख ३१ | विष्णुप्रसाद अयालसँग कि.नं. ६६१ को जग्गाको रु.१ करोड १० लाख बैनापट्टा कागज हेरी सनाखत गरिदिइन्। उक्त नगद रकम आफ्नो व्यवसायबाट आफैंले दिएको भनिन्। पहिला बिर्सेको, कागजात हेरेपछि याद आएको जनाइन्। जग्गाखरिदको लेनदेन कागजी प्रमाण प्रमाणित गरिदिन आयोगसँग अनुरोध समेत गरिन्। |\r\n| ५ | कृष्ण प्रसाद मेहता रीना कुशवाहाका श्रीमान | २०८२ वैशाख ०४ | रामबाबु महतोलाई २०६० सालदेखि चिनेको, महतोले त्रियोग सहकारीमा जमानी राखी नगद कारोबारमा सहयोग गरेको बताए। श्रीमती रीना कुशवाहाको नाममा बुढानीलकण्ठ कि.नं. ११४३ को जग्गा रु.२ करोड १७ लाख ५० हजारमा खरिद गरेको, रकम चेक र बैंक भौचरबाट बुझाएको जनाए। विक्रेतालाई बुझाएको रु.३ करोडमध्ये रु.८२ लाख ५० हजार नगद फिर्ता लिएको र रामबाबुले आफूहरूका लागि रु.४० लाख ऋण दिलाएको उल्लेख गरे। |\r\n| ६ | जिवराज पोखरेल सावित्री पोखरेलका श्रीमान | २०८२ वैशाख १० | श्रीमती सावित्री पोखरेलले धनुषा हरिहरपुर कि.नं. २६१५ र १६०१ को जग्गा माला कुमारी महतोलाई रु.६४ लाखमा बेचेको बताए। उक्त कित्तामा घर नभएको, दर्तामा घर कसरी उल्लेख भयो थाहा नभएको जनाए। रकम जेठमा रु.५ लाख, माघमा रु.१० लाख, कुमारी बैंकबाट रु.३७ लाख २८ हजार र पटकपटक बाँकी रकम राष्ट्र बैंक खातामा रामबाबुले जम्मा गरेको बताए। |\r\n| ७ | किरण पुन मगर जग्गा विक्रेता (संयुक्त नाम) | २०८२ वैशाख १९ | बुढानीलकण्ठ साबिक वि.नं. ६६१ को जग्गा तीन जनाको संयुक्त नाममा भएको, कि.नं. ११४२ र ११४३ प्रतिआना रु.३३ लाखका दरले विष्णुप्रसाद अयालमार्फत बेचेको जनाए। बैंकबाट रु.४ करोड ७२ लाख र नगद रु.७२ लाख ५० हजार सामूहिक रूपमा प्राप्त भएको, माला कुमारी महतोको पैसा रीना कुशवाहामार्फत आएको, र खरिदकर्ताले फरक फरक लिखत बनाएको बताए। |\r\n| ८ | दीपक गुरुङ पुन जग्गा विक्रेता (संयुक्त नाम) | २०८२ वैशाख १९ | संयुक्त नाममा रहेको कि.नं. ११४२ र ११४३ को जग्गा प्रतिआना रु.३३ लाखका दरले विष्णुप्रसाद अयाललाई बेचेको, अयालले नै माला कुमारी महतो र रीना कुशवाहालाई पुनः बेचेको बताए। बैनाबापत रु.१ करोड २ लाख चेकबाट, सेञ्चुरी बैंकमा रु.१ करोड ९० लाख, एभरेष्ट बैंकमा रु.१ करोड ८० लाख र नगद रु.७२ लाख ५० हजार प्राप्त भएको, श्रीराज राजभण्डारी बैंक जानका लागि मात्र गएको उल्लेख गरे। |\r\n| ९ | श्याम नारायण पुन चन्द्रमान पुनका अधिकृत वारेस | २०८२ वैशाख १९ | छोरा चन्द्रमान पुनको अधिकृत वारेसको रूपमा कि.नं. ११४२ र ११४३ को जग्गा प्रतिआना रु.३३ लाखमा बेचेको जनाए। विष्णुप्रसाद अयालसँग घरायसी तमसुक गरी जग्गा बैना गरिएको, पछि अयालले माला कुमारी महतो र रीना कुशवाहालाई बेचेको बताए। सिद्धार्थ बैंकबाट रु.१ करोड २ लाख, एभरेष्ट बैंकबाट रु.१ करोड १० लाख, रु.७० लाख नगद, साबिक सेञ्चुरी बैंकबाट रु.१ करोड ९० लाख र नगद रु.७२ लाख ५० हजार सामूहिक रूपमा प्राप्त भएको उल्लेख गरे। |\r\n| १० | विष्णुप्रसाद अर्याल जग्गा दलाल — प्रथम घटना विवरण | २०८० पुष २२ | विगत ५ वर्षदेखि जग्गा खरिद-बिक्री सम्बन्धी काम गर्ने बताए। किरण पुनसमेतको नाममा रहेको कि.नं. ११४२, क्षेत्रफल ०-८-१-१ को जग्गा प्रतिआना रु.३३ लाखमा बैना गरी प्रतिआना रु.३६ लाखका दरले माला कुमारी महतोलाई मिति २०७८/०४/०८ मा बेचेको जनाए। रामबाबु महतोको नेपाल एसबिआई बैंकको चेकमार्फत मिति २०७८/०४/११ मा रु.२९ लाख १० हजार विक्रीबापत प्राप्त गरेको उल्लेख गरे। |\r\n| ११ | विष्णुप्रसाद अर्याल जग्गा दलाल — दोस्रो घटना विवरण |  | किरण पुनसमेतको संयुक्त नाममा रहेको जग्गा मिति २०७७/१०/०७ मा सिद्धार्थ बैंकको आफ्नो र भान्जा रोहन सिग्देलको चेकबाट रु.१ करोड २ लाख बैना दिएर घरायसी कागज गरेको बताए। सो रकम रामबाबु महतो र कृष्ण प्रसाद मेहता दुवैले नगद र चेकमार्फत दिएका थिए। रीना कुशवाहासँग रु.१ करोड १० लाख बैना कागज गरी नगद लिएको र मालपोत कार्यालयमा विक्रेतालाई रु.७२ लाख ५० हजार बुझाएको जनाए। |\r\n| १२ | श्रीराज राजभण्डारी |  | श्रीराज राजभण्डारीले आफू जग्गा विक्रेता पक्षको सहयोगीको रूपमा मात्र उपस्थित भएको बताएका थिए । उनले रीना कुशवाहाले बैंकमा रु.१ करोड नगद ल्याई विक्रेताको खातामा जम्मा गरेको बताए। उक्त रकमको स्रोत आफूलाई जानकारी नभएको उल्लेख गरे। जग्गाको वास्तविक कारोबार प्रतिआना रु.३३ लाखका दरले भएको सुनेको तथा मालपोत कार्यालयमै केही नगद रकम लेनदेन भएको बताए। लिखतमा मूल्य फरक किन राखियो भन्ने आफूलाई जानकारी नभएको बताए। |","key_allegations":["काठमाडौँ महानगरपालिकामा कार्यरत इन्जिनियर (उपनिर्देशक) रामबाबु महतो कोइरीले सार्वजनिक पद धारण गरेको अवधिमा कानुनी आम्दानीभन्दा बढी मात्रामा सम्पत्ति आर्जन गरेको आरोप। आर्थिक वर्ष २०४५/४६ देखि २०७८/७९ सम्मको आय-व्यय विश्लेषणमा निरन्तर स्रोत अपुग अवस्था देखिएको।","मिति २०७०/१०/१२ र २०८१/०५/०९ तथा २०८१/०५/१३ मा अख्तियार दुरुपयोग अनुसन्धान आयोगमा परेको उजुरीमा भ्रष्टाचार गरी अवैध सम्पत्ति आर्जन गरेको आरोप लगाइएको । चःमती परियोजनामा रहँदा गैरकानूनी रकम आर्जन गरी बुढानिलकण्ठ क्षेत्रमा जग्गा खरिद गरेको, आफन्तहरूको नाम प्रयोग गरी सम्पत्ति व्यवस्थापन गरेको तथा सम्पत्ति शुद्धीकरण गरेको उजुरी दाबी।","आर्थिक वर्ष २०४५/४६ देखि २०७८/७९ सम्मको आय-व्यय विश्लेषण गर्दा प्रतिवादी रामबाबु महतोको वैधानिक आय स्रोतभन्दा खर्च तथा लगानी अत्यधिक बढी हुँदा कूल  रु.४,५८,९७,४०३। ८८ (चार करोड अन्ठाउन्न लाख सन्तानब्बे हजार चार सय तीन रुपैयाँ अठासी पैसा)  बराबरको स्रोत अपुग देखिएको। मुख्यतः जग्गा खरिद, घर निर्माण, ऋण भुक्तानी, बीमा शुल्क, अध्ययन शुल्क तथा शेयर खरिदमा अत्यधिक खर्च भएको पाइएको।","श्रीमती माला कुमारी महतोको नाममा जग्गा खरिद, शेयर खरिद, घर निर्माण र बैङ्क मौज्दात समेतको सम्पत्ति भ्रष्टाचार निवारण ऐन, २०५९ को दफा ४७ तथा अख्तियार दुरूपयोग अनुसन्धान आयोग ऐन, २०४८ को दफा २९ख. समेतको प्रचलित कानून बमोजिम जफत गर्ने प्रयोजनार्थ मात्र निज माला कुमारी महतोलाई प्रतिवादी कायम गरिएको।"],"timeline":[{"date":"1988-07-16","title":"आय-व्यय विश्लेषण — आ.व. २०४५/४६ देखि २०४९/५० सम्म","date_bs":"2045-04-01","description":"रामबाबु महतोको आयआर्जनतर्फ सार्वजनिक सेवा प्रवेशपूर्वको आय बचत रु.२१,७००.०० तथा पारिश्रमिक बचत रु.६१,७७८.५० समेत गरी कूल आयआर्जन रु.८३,४७८.५०। सुनचाँदी खरिद रु.३,०००.०० खर्च भएकाले कूल खर्च घटाउँदा रु.८०,४७८.५० बचत रहेको। यस अवधिमा आयभन्दा खर्च कम हुँदा वैधानिक बचत कायम रहेको।"},{"date":"1989-05-01","title":"सार्वजनिक पद धारण गरेको र् जाँच अवधि सुरू","date_bs":"2046-01-19","description":"प्रतिवादीले सार्वजनिक पद धारण गरेको मिति र अख्तियार दुरूपयोग  अनुसन्धान आयोगद्वारा प्रतिवादीको  आ.व. २०४५/४६ देखि  २०७८/७९ सम्मको आय-व्यय स्रोत खोजीको लागि निर्धारण गरेको सुरुवाती अवधि ।"},{"date":"1993-07-16","title":"आय-व्यय विश्लेषण — आ.व. २०५०/५१ देखि २०५४/५५ सम्म","date_bs":"2050-04-01","description":"अघिल्लो बचत रु.८०,४७८.५०, पारिश्रमिक बचत रु.१,०४,४४८.९४ तथा ऋण सापटी रु.२,००,०००.०० समेत गरी कूल आयआर्जन रु.३,८४,९२७.४४। जग्गा खरिद रु.१,१२,५००.००, शेयर खरिद रु.५००.००, सुनचाँदी खरिद रु.३०,०००.०० खर्च हुँदा कूल खर्च रु.१,४३,०००.००। खर्च कटाउँदा रु.२,४१,९२७.४४ बचत रहेको।"},{"date":"1998-07-17","title":"आय-व्यय विश्लेषण — आ.व. २०५५/५६ (पहिलो स्रोत अपुग)","date_bs":"2055-04-01","description":"अघिल्लो बचत रु.२,४१,९२७.४४ र पारिश्रमिक बचत रु.३०,५८१.९८ समेत कूल आयआर्जन रु.२,७२,५०९.४२। काठमाडौं महानगरपालिका वडा नं. ४ चण्डोलस्थित जग्गामा २.५ तलाको घर निर्माणमा रु.१६,१७,२२०.५६ खर्च हुँदा रु.१३,४४,७११.१७ स्रोत अपुग भई ऋणात्मक अवस्था सिर्जना भएको।"},{"date":"1999-07-17","title":"आय-व्यय विश्लेषण — आ.व. २०५६/५७ देखि २०५७/५८ सम्म","date_bs":"2056-04-01","description":"पारिश्रमिक बचत रु.८१,९६०.०६। जग्गा खरिद रु.९८,०००.००, रजिष्ट्रेशन दस्तुर रु.१,९६०.००, मोटरसाइकल खरिद रु.९९,११०.०० खर्च हुँदा कूल खर्च रु.१,९९,०७०.००। आयभन्दा खर्च बढी हुँदा रु.१,१७,३७९.९४ स्रोत अपुग भएको।"},{"date":"2001-07-16","title":"आय-व्यय विश्लेषण — आ.व. २०५८/५९ देखि २०६२/६३ सम्म","date_bs":"2058-04-01","description":"पारिश्रमिक बचत रु.२,७६,८५४.०० र ब्याज आय रु.१,२३४.०५ समेत कूल आयआर्जन रु.२,७८,०८८.०५। जग्गा खरिद, रजिष्ट्रेशन, अध्ययन शुल्क र बीमा शुल्क गरी कूल खर्च रु.२,१७,७२५.३७। खर्च कटाउँदा रु.६०,३६२.६८ बचत रहेकाले वैधानिक आय स्रोत पर्याप्त रहेको।"},{"date":"2006-07-17","title":"आय-व्यय विश्लेषण — आ.व. २०६३/६४","date_bs":"2063-04-01","description":"अघिल्लो बचत रु.६०,३६२.६८, पारिश्रमिक बचत रु.६४,८४४.४८ र ब्याज आय रु.२,४५१.४६ समेत कूल आय रु.१,२८,६५७.६२। कृषि विकास बैंक ऋण भुक्तानी रु.५,२४,४१६.६७, अध्ययन शुल्क रु.२९,८५९.७०, बीमा शुल्क रु.२७,८०५.०० गरी कूल खर्च रु.५,८२,०८१.३७। रु.४,५३,४२३.७५ स्रोत अपुग भएको।"},{"date":"2007-07-17","title":"आय-व्यय विश्लेषण — आ.व. २०६४/६५ देखि २०६५/६६ सम्म","date_bs":"2064-04-01","description":"पारिश्रमिक बचत रु.१,७९,५८३.३६ र ब्याज आय रु.४,४९८.०६ गरी कूल आय रु.१,८४,०८१.४२। शेयर 