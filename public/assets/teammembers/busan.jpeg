splay_name":"अमर दीप महतो","type":"related","notes":""},{"id":2140,"nes_id":"entity:person/amarendra-kumaara-mishra","display_name":"अमरेन्द्र कुमार मिश्र","type":"related","notes":""},{"id":2141,"nes_id":"entity:person/karmashila-prasaada-gopa","display_name":"कर्मशिल प्रसाद गोप","type":"related","notes":""},{"id":2142,"nes_id":"entity:person/gunaananda-prasaada-saaha","display_name":"गुणानन्द प्रसाद साह","type":"related","notes":""},{"id":2145,"nes_id":"entity:person/ramesha-kumaara-mandala","display_name":"रमेश कुमार मण्डल","type":"related","notes":""},{"id":2147,"nes_id":"entity:person/mana-mohana-mishra","display_name":"मन मोहन मिश्र","type":"related","notes":""},{"id":2148,"nes_id":"entity:person/dipendra-kumaara-mishra","display_name":"दिपेन्द्र कुमार मिश्र","type":"related","notes":""},{"id":2133,"nes_id":"entity:person/ima-naaraayana-shreshtha","display_name":"इम नारायण श्रेष्ठ","type":"accused","notes":""},{"id":2134,"nes_id":"entity:person/shravana-kumaara-mishra","display_name":"श्रवण कुमार मिश्र","type":"accused","notes":""},{"id":2135,"nes_id":"entity:person/navina-daasa","display_name":"नविन दास","type":"accused","notes":""},{"id":2136,"nes_id":"entity:person/mukti-naaraayana-saaha","display_name":"मुक्ति नारायण साह","type":"accused","notes":""},{"id":2137,"nes_id":"entity:organization/vishaala-pandita-haspiteka-intarapraaijeja-praa-li-kaa-sanchaalaka","display_name":"विशाल पण्डित-हस्पिटेक इन्टरप्राइजेज प्रा.लि.का संचालक","type":"accused","notes":""},{"id":2138,"nes_id":"entity:organization/haspiteka-intarapraaijeja-praa-li","display_name":"हस्पिटेक इन्टरप्राइजेज प्रा.लि","type":"accused","notes":""},{"id":2139,"nes_id":"entity:person/amara-deepa-mahato","display_name":"अमर दीप महतो","type":"accused","notes":""},{"id":2140,"nes_id":"entity:person/amarendra-kumaara-mishra","display_name":"अमरेन्द्र कुमार मिश्र","type":"accused","notes":""},{"id":2141,"nes_id":"entity:person/karmashila-prasaada-gopa","display_name":"कर्मशिल प्रसाद गोप","type":"accused","notes":""},{"id":2142,"nes_id":"entity:person/gunaananda-prasaada-saaha","display_name":"गुणानन्द प्रसाद साह","type":"accused","notes":""},{"id":2145,"nes_id":"entity:person/ramesha-kumaara-mandala","display_name":"रमेश कुमार मण्डल","type":"accused","notes":""},{"id":2147,"nes_id":"entity:person/mana-mohana-mishra","display_name":"मन मोहन मिश्र","type":"accused","notes":""},{"id":2148,"nes_id":"entity:person/dipendra-kumaara-mishra","display_name":"दिपेन्द्र कुमार मिश्र","type":"accused","notes":""}],"tags":["nphl","Public Procurement"],"description":"प्रस्तुत मुद्दामा अख्तियार दुरुपयोग अनुसन्धान आयोग ले मधेस प्रदेशको जनस्वास्थ्य प्रयोगशाला स्थापना सम्बन्धी खरिद प्रक्रियामा गम्भीर अनियमितता भएको भन्दै आरोप लगाएको थियो। आयोगका अनुसार सार्वजनिक खरिद ऐन, २०६३ तथा अन्य प्रचलित कानुनी व्यवस्थाअनुसार आवश्यक लाभ–लागत विश्लेषण, खरिद गुरुयोजना तथा पूर्वतयारी नगरी खरिद प्रक्रिया अघि बढाइएको थियो र एउटै कार्यक्रमलाई स्पष्ट आधार बिना दुई ठेक्कामा विभाजन गरिएको भनी आरोप लगाएको थियो।\r\n\r\nसम्झौताअनुसार उपकरणहरू स्थापना नगरिएको, रिएजेन्टहरू प्रयोग हुनु अघि नै म्याद गुज्रिएको अवस्थामा रहेको तथा त्यस्ता म्याद गुज्रेका रिएजेन्ट प्रयोग गरिएको आरोप लगाइएको थियो। वास्तविक कार्य सम्पन्न नभए पनि PDI Report मार्फत कार्य सम्पन्न भएको भनी गलत प्रतिवेदन तयार गरी भुक्तानी गरिएको उल्लेख गरिएको थियो। आयोगले स्वार्थ बाँझिने अवस्था सिर्जना गरी मिलेमतोमा प्राविधिक स्पेसिफिकेशन तयार गरिएको र प्रतिस्पर्धात्मक बोलपत्र प्रक्रिया प्रभावित गरिएको र आवश्यकता र औचित्यता पुष्टि नगरी उच्च क्षमताका उपकरणहरू अस्वाभाविक रूपमा बढी संख्यामा खरिद गरिएको र सोबाट रू. २१,८९,३९,७६० बराबरको सार्वजनिक रकममा हानिनोक्सानी भएको दाबी गरेको थियो।\r\n\r\nप्रतिवादीहरूलाई भ्रष्टाचार निवारण ऐन, २०५९ को दफा ८(१) (क), (च), (ञ) बमोजिम भ्रष्टाचार कसुरमा कैद र बिगो बराबर जरिवाना तथा बिगो असुल उपर माग गरिएको थियो। साथै, गलत प्रतिवेदन तयार गर्नेहरूलाई सोही ऐनको दफा १९(२) अनुसार थप सजाय र मुख्य कसुरदारलाई दफा २४ बमोजिम अतिरिक्त सजायको माग गरिएको थियो भने सहयोगी (मतियार) तर्फ दफा २२ अनुसार मुख्य कसुरदार सरह सजाय मागदाबी गरिएको थियो।\r\n\r\nमिति २०८२-०१-१५ मा दर्ता भएको मुद्दा मिति २०८२-११-१३ मा विशेष अदालतले लामो सुनुवाइपछि प्रस्तुत प्रमाण र कानुनी आधार पर्याप्त नदेखिएको ठहर गर्दै विशेष अदालतका अध्यक्ष सुदर्शनदेव भट्ट तथा न्यायाधीशहरू हेमन्त रावल र डिल्लीरत्न श्रेष्ठको इजलासले भ्रष्टाचार मुद्दामा अभियोग प्रमाणित नभएको ठहर गर्दै सबै प्रतिवादीलाई निर्दोष ठहरगरी सफाई दिने फैसला गरेको थियो। यद्यपि विशेष अदालतको फैसलाको पूर्णपाठ भने सार्वजनिक भैसकेको छैन।\r\n\r\n<br>\r\nRelated Cases\r\n\r\n* 081-CR-0079\r\n\r\n\r\n* 081-CR-0080\r\n\r\n\r\n* 081-CR-0082\r\n\r\n\r\n<br>","key_allegations":["प्रतिवादीहरूले आपसी मिलेमतोमा जिल्ला धनुषा, प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामबाट आ.व. २०७९/८० मा आह्वान गरिएको ठेक्का नं. PPHL2/G/NCB/01/2079-80 अन्तर्गत Pathology Lab स्थापना गर्न उपकरण तथा रियाजेन्ट खरिद गर्दा प्रचलित सार्वजनिक खरिद ऐन तथा नियमावली विपरीत कार्य गरेको आरोप उल्लेख गरिएको ।","खरिद कार्यको गुरुयोजना, प्राविधिक अध्ययन तथा आवश्यक पूर्वतयारी नगरी बजेट माग गरी ठेक्का टुक्र्याउने, बोलपत्रदातासँग मिलेमतो गरी लागत अनुमान र स्पेसिफिकेशन तयार गर्ने कार्य भएको ।","प्रतिस्पर्धा सीमित गर्ने उद्देश्यले बोलपत्र प्रक्रिया छोट्याउने तथा Installation र Commissioning पूरा नभए पनि उपकरणको भुक्तानी गर्ने कार्य गरी राज्यलाई आर्थिक हानि पुर्‍याएको अभियोग लगाइएको ।"],"timeline":[{"date":"2022-05-29","title":"आ.व. २०७९।८० को नीति तथा कार्यक्रम","date_bs":"2079-02-15","description":"मधेश सरकारको नीति तथा कार्यक्रमको बुँदा नं. ७९ मा प्रदेश जनस्वास्थ्य प्रयोगशाला मार्फत आठै जिल्लामा रहेका विभिन्न स्वास्थ्य प्रयोगशालाहरुको सुधृढीकरण तथा गुणस्तर अभिवृद्धिको लागि पुर्वाधार निर्माण, थप जनशक्ति र उपकरणको व्यवस्था गरिनेछ भनी उल्लेख भएको।"},{"date":"2022-05-29","title":"आ.व. २०७९।०८० को बजेट सुनश्चितता","date_bs":"2079-02-15","description":"७२ वटा पालिका स्तरिय जनस्वास्थ्य प्रयोगशाला (निदान केन्द्र। स्थापनाको लागि Nidan Lab for each Municipality (७२ वटा पालिकाको लागि) शिर्षकमा रु. ३०,००,००,०००।- (अक्षरुपी तीस करोड माव। बजेट विनियोजन भएको।"},{"date":"2022-07-25","title":"स्पेशिफिकेशन स्वीकृती","date_bs":"2079-04-09","description":"स्पेशिफिकेशन तयार गर्नेः, जितेन्द्र कुमार साह (माइकोबाइलोजिस्ट), अमरेन्द्र कुमार मिश्र (माइकोबाइलोजिस्ट), उप-प्रमुख मेडिकल टेक्नोलोजिष्ट दिपेन्द्र कुमार मिश्र रमेश कुमार मण्डल (ल्याब असिस्टेन्ट) र स्वीकृत गर्नेः निर्देशक डा. भवन कुमार मिश्र।"},{"date":"2022-07-26","title":"फर्मलाई पत्राचार","date_bs":"2079-04-10","description":"आ.व. २०७९।०८० को लागि मधेश प्रदेशको ७२ वटा पालिकाहरुमा प्रयोगशाला स्थापना गर्न ल्याव सम्बन्धि उपकरण तथा रिएजेन्टको दररेट पेश गर्न लाईफ लाईन ईन्टरनेशनल प्रा.लि., कस्तुरी ट्रेड लिंक प्रा.लि., मेडि सोलुसन इन्टरनेशनल प्रा.लि. र ट्रिनिटी फर्मास्युटिकल्स लाई पत्राचार गरेको।"},{"date":"2022-07-29","title":"फर्मबाट दररेट पेस","date_bs":"2079-04-13","description":"४ वटै फर्मबाट दररेट पेस भएको।"},{"date":"2022-07-29","title":"लागत अनुमान स्वीकृत","date_bs":"2079-04-13","description":"सामाजिक विकास मन्त्रालय, मधेस प्रदेशका तत्कालिन सचिव श्री ईम नारायण श्रेष्ठले लागत अनुमान रु.२२.४४,५१,९००।- स्वीकृत गरेको।"},{"date":"2022-07-29","title":"बोलपत्र कागजात स्वीकृत","date_bs":"2079-04-13","description":"निर्देशक डा.श्री श्रवण कुमार मिश्रबाट स्वीकृत।"},{"date":"2022-08-02","title":"बोलपत्र आह्वानको सुचना","date_bs":"2079-04-17","description":"ल्याव सम्बन्धि उपकरण तथा रिएजेन्टको खरिदको लागि रू. रु.२२.४४.५१.९००/- लागत अनुमानको विद्युतिय बोलपत्रको ३० दिनको म्याद दिई सूचना आव्हान भएको र सोही मितिमा ठेका नं. PPHL2/G/NCB-01/2079-80 को लागि सुचना प्रकाशन भएको।"},{"date":"2022-09-05","title":"बोलपत्र प्रस्ताव पेस","date_bs":"2079-05-20","description":"३ (तीन) बटा बोलपत्रदाताहरु ओम सर्जिकल कन्सर्न प्रा.लि., हस्पिटेक ईन्टरप्राईजेज प्रा.लि., म्याक्सिमम ईन्कर्पोरेसन ट्रेडर्स प्रा.लि.ले बोलपत्र पेश गरेको।"},{"date":"2022-09-05","title":"प्राविधिक मुल्याङ्कन समितिको निर्णय","date_bs":"2079-05-20","description":"प्रयोगशाला मुल्याङ्कन समिति (माईक्रोबाईलोजिस्ट जितेन्द्र कुमार साह, माईक्रोबाईलोजिस्ट अमरेन्द्र कुमार मिश्र, उप प्र.मे.टे. दिपेन्द्र कुमार मिश्र र ल्या.अ. रमेश कुमार मण्डल) ले ठेक्का नं,PPHL2/G/NCB/01/2079-80 को हस्पिटेक ईन्टरप्राईजेज प्रा.लि. काठमाडौले पेश गरेको बोलपत्र स्वीकृतिको लागि कार्यालयमा सिफारिस गर्ने भनी निर्णय गरेको।"},{"date":"2022-09-07","title":"बोलपत्र मुल्याकंन समितिको निर्णय","date_bs":"2079-05-22","description":"बोलपत्र मुल्यांकन समिति (उमेश चौधरी (ब.ल्या.अ.), अमर दिप महतो (लेखा अधिकृत।, कर्मशिल प्रसाद गोप (ल्या.अ.) र गुणानन्द प्रसाद साह (ब.ल्या.टे.नि.।) ले ठेक्का नं. PPHL2/G/NCB-01/2079-80 को लागि पेश हुन आएको बोलपत्रको Responsive Chart तयार गरी अध्ययन गर्दा श्री हस्पिटेक ईन्टरप्राईजेज प्रा.लि. काठमाडौले पेश गरेको बोलपत्र न्यूनतम मूल्याङ्कित सारभूत रुपमा प्रभावग्राही देखिएकोले निजको कयोल अंक रु. २१.८९.३९७६०।-(मु.अ.कर सहित) को बोलपत्र स्वीकृतिको सिफारिस गरेको।"},{"date":"2022-09-14","title":"बोलपत्र स्वीकृति र आसयको सुचना","date_bs":"2079-05-29","description":"बोलपत्रदाता श्री हस्पिटेक ईन्टरप्राईजेज प्रा.लि., काठमाडौले पेश गरेको बोलपत्र न्यूनतम मूल्यावित सारभूत रुपमा प्रभावग्राही देखिएकोले निजको बोलपत्र मिति २०७९।०५।२२ मा स्वीकृत भई मिति २०७९।०५।२९ मा आसयको सुचना प्रकाशन भएको।"},{"date":"2022-10-12","title":"सम्झौता र कार्यदिशा","date_bs":"2079-06-26","description":"प्रयोगशालाको तर्फबाट निर्देशक डा. श्रवण कुमार मिश्र र श्री हस्पिटेक ईन्टरप्राईजेज प्रा.लि., काठमाडौंको तर्फबाट आधिकारिक प्रतिनिधी प्रविन कुमार मिश्रले हस्ताक्षर गरेको।"},{"date":"2025-10-13","title":"Post Delivery Inspection","date_bs":"2082-06-27","description":"ब.ल्या.अ. उमेश चौधरी र निर्देशक डा. श्रवण कुमार मिश्रले \"The equipment is delivered at PPHL Site\" भनी प्रतिवेदन पेश गरेको ।"},{"date":"2025-10-13","title":"खरिद आदेश र दाखिला प्रतिवेदन","date_bs":"2082-06-27","description":"कार्यालयबाट मिति २०७९।०६।२६ मा खरिद आदेश र मिति २०७९।०६।२७ मा दाखिला प्रतिवेदन जिन्सी प्रमुख कर्मशिल प्रसाद गोप (ल्या.अ.) ले तयार गरी निर्देशक डा. श्रवण कुमार मिश्रले स्वीकृत गरेको।"},{"date":"2022-10-14","title":"हस्पिटेक इन्टरप्राइजेज प्रा.लि.लाई भुक्तानी","date_bs":"2079-06-28","description":"गो. भौ.नं.३ बाट रु. ३.७३.०५३.६०।- (कर बाहेक) र मिति २०७९।०७।१५ गो.भौ.नं.५ बाट १६.१४,८४१९२।-(कर बाहेक) भुक्तानी भएको।"},{"date":"2022-10-31","title":"प्रयोगशाला मुल्याङ्कन समितिको निर्णय","date_bs":"2079-07-14","description":"प्रयोगशाला मुल्याङ्कन समिति (व.ल्या.अ. उमेश चौधरी, ले.अ. अमरदीप महतो, ल्या.अ. कर्मशील प्रसाद गोप, ब.ल्या.टे.नि. गुणानन्द प्रसाद साह र आमन्त्रित निर्देशक डा. श्रवण कुमार मिश्र) ले ठेक्का नं. PPHL2/G/NCB/01/2079-80, Supply, Delivery and Installation of Equipments and reagents for establishment of Pathology Lab in Municipality को लागि हस्पिटेक ईन्टरप्राईजेज प्रा.लि., काठमाडौले प्रयोगशालामा आपूर्ती गरेको मालसामानहरू मध्येबाट Random Sampling गरी Post delivery Inspection प्रतिवेदन अनुसार Verification गर्दा नमुनाहरू बोलपत्रमा माग भए बमोजिम देखिएको हुँदा अगाडी प्रक्रियाको लागि सिफारिस गर्ने निर्णय गरेको।"},{"date":"2024-01-19","title":"अख्तियार दुरुपयोग अनुसन्धान आयोगको स्थलगत प्रतिवेदन","date_bs":"2080-10-05","description":"प्रारम्भिक छानबिन तथा स्थलगत अनुगमनबाट प्रदेश जनस्वास्थ्य प्रयोगशालाले २०७९।०४।१७ मा आह्वान गरेको ठेक्का मार्फत ७२ सेट प्रयोगशाला उपकरण (Biochemistry Analyzer, Hematology Analyzer, Microscope लगायत) र आवश्यक रिएजेन्टहरू Hospitec Enterprises Pvt. Ltd. सँग सम्झौता गरी खरिद गरेको देखिन्छ। सम्बन्धित स्वास्थ्य चौकीहरूमा उपकरण जडान भई प्रयोगशाला सञ्चालनमा रहेको अवस्था अनुगमन, नापजाँच तथा मुचुल्का उठानबाट पुष्टि भएको। आदि।"},{"date":"2024-03-18","title":"अख्तियार दुरुपयोग अनुसन्धान आयोगको स्थलगत प्रतिवेदन","date_bs":"2080-12-05","description":"१३४ पालिकामा जडान भएका प्रयोगशाला उपकरणहरू प्रायः प्रयोगविहीन वा बन्द अवस्थामा रहेको पाइयो। रिएजेन्ट अभाव, जनशक्ति, विद्युत र इन्टरनेट समस्याका कारण सञ्चालन न्यून देखियो। कतिपय स्थानमा उपकरण जडान नै नभएको, कतै जगेडामा राखिएको तथा म्याद गुज्रेका रिएजेन्ट प्रयोग भइरहेको भेटियो। आवश्यकता र बिरामी चापभन्दा अत्याधिक क्षमताका उपकरण खरिद गरी सार्वजनिक सम्पत्तिको हानिनोक्सानी भएको निष्कर्ष निकालिएको। आदि।"},{"date":"2025-04-27","title":"अख्तियार दुरुपयोग अनुसन्धान आयोगको प्रेस विज्ञप्ति","date_bs":"2082-01-14","description":"प्रतिवादीहरूले आपसी मिलेमतोमा जिल्ला धनुषा, प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामबाट आ.व. २०७९/८० मा आह्वान गरिएको ठेक्का नं. PPHL2/G/NCB/01/2079-80 अन्तर्गत Pathology Lab स्थापना गर्न उपकरण तथा रियाजेन्ट खरिद गर्दा प्रचलित सार्वजनिक खरिद ऐन तथा नियमावली विपरीत कार्य गरेको आरोप उल्लेख गरिएको छ । खरिद कार्यको गुरुयोजना, प्राविधिक अध्ययन तथा आवश्यक पूर्वतयारी नगरी बजेट माग गरी ठेक्का टुक्र्याउने, बोलपत्रदातासँग मिलेमतो गरी लागत अनुमान र स्पेसिफिकेशन तयार गर्ने, प्रतिस्पर्धा सीमित गर्ने उद्देश्यले बोलपत्र प्रक्रिया छोट्याउने तथा Installation र Commissioning पूरा नभए पनि उपकरणको भुक्तानी गर्ने कार्य गरी राज्यलाई आर्थिक हानि पुर्‍याएको अभियोग लगाइएको प्रेस विज्ञप्ति ।"},{"date":"2026-02-25","title":"फैसला","date_bs":"2082-11-13","description":"विशेष अदालतले लामो सुनुवाइपछि प्रस्तुत प्रमाण र कानुनी आधार पर्याप्त नदेखिएको ठहर गर्दै विशेष अदालतका अध्यक्ष सुदर्शनदेव भट्ट तथा न्यायाधीशहरू हेमन्त रावल र डिल्लीरत्न श्रेष्ठको इजलासले भ्रष्टाचार मुद्दामा अभियोग प्रमाणित नभएको ठहर गर्दै सबै प्रतिवादीलाई निर्दोष ठहर गरी सफाई दिने फैसला गरेको।"}],"evidence":[{"source_id":"source:20260325:de3cd91f","description":"CIAA"},{"source_id":"source:20260325:a8f33fd2","description":"OAG"},{"source_id":"source:20260320:76053052","description":"NEPAL LAW COMMISSION"},{"source_id":"source:20260320:d94b7d33","description":"NEPAL LAW COMMISSION"},{"source_id":"source:20260320:44bd104b","description":"NEPAL LAW COMMISSION"},{"source_id":"source:20260323:40bb07d0","description":"Shilapatra — Article published on Baisakh 15, 2082 (April 28, 2025)"},{"source_id":"source:20260320:bd302182","description":"Nepal Press — April 27, 2025"},{"source_id":"source:20260320:bdb056dd","description":"Nepal Health News — Falgun 14, 2082"}],"notes":"Case drafted by Rujit Kafle. First published on March 31, 2026.\r\n\r\nCase updated on 04/01/2026 with note: ⁠Minor corrections.","court_cases":["supreme:080-CR-0081"],"missing_details":"क) प्रतिवादीहरूले अदालतमा गरेको बयानको ब्याहोरा\r\n\r\nख) प्रस्तुत मुद्दासँग सम्बद्ध थप आधार र प्रमाण पुष्टि गर्ने प्रमाणिक स्रोत\r\n\r\nग) विशेष अदालतको फैसलाको प्रतिलिपि\r\n\r\nघ) अन्य आवश्यक स्रोतहरू।","bigo":null,"versionInfo":{},"created_at":"2026-03-25T17:10:42.537340+05:45","updated_at":"2026-05-20T15:10:12.109274+05:45"},{"id":213,"case_id":"case-53c2e35405ac","slug":"case-080-cr-0158-8a2709","case_type":"CORRUPTION","state":"PUBLISHED","title":"सुनिल पौडेलकाे २३ कराेडकाे गैरकानुनी सम्पती आर्जन (080-CR-0158)","short_description":".","thumbnail_url":"https://s3.jawafdehi.org/case_uploads/f69708e488c98dfe9fd10f7fee2dc6c206d890b61e3a2273b8bf8317bee39911.png","banner_url":"","case_start_date":"2081-01-09","case_end_date":null,"entities":[{"id":2010,"nes_id":null,"display_name":"Singha Durbar","type":"location","notes":""},{"id":2151,"nes_id":null,"display_name":"काठमाण्डाै","type":"location","notes":""},{"id":2106,"nes_id":null,"display_name":"InstaSafe Technologies Pvt. Ltd.","type":"related","notes":""},{"id":2114,"nes_id":null,"display_name":"Maxim International Pvt. Ltd","type":"related","notes":""},{"id":2128,"nes_id":null,"display_name":"World Distribution Nepal Pvt. Ltd.","type":"related","notes":""},{"id":2159,"nes_id":null,"display_name":"BancTec Pte Ltd","type":"related","notes":""},{"id":2160,"nes_id":null,"display_name":"UOB Singapore बैंक","type":"related","notes":""},{"id":2162,"nes_id":null,"display_name":"राष्ट्रिय  सूचना प्रविधि केन्द्र","type":"related","notes":""},{"id":2163,"nes_id":null,"display_name":"अनिल पाैडेल","type":"related","notes":""},{"id":2165,"nes_id":null,"display_name":"Next Gen Solution","type":"related","notes":""},{"id":2104,"nes_id":"entity:person/sunila-paudela","display_name":"सुनिल पौडेल","type":"accused","notes":""},{"id":2163,"nes_id":null,"display_name":"अनिल पाैडेल","type":"accused","notes":""}],"tags":["Procurement","CIAA","NITC","080-CR-0158"],"description":"सुनिल पौडेल मिति २०६१/०२/२० मा राष्ट्रिय सूचना प्रविधि केन्द्र, सिंहदरवारमा प्रशासकीय अधिकृतको पदमा करार सेवामा नियुक्त भई अनेक पदमा कार्यरत रहदै मिति २०७८/१२/२५ मा नेपाल दुरसञ्चार कम्पनी लिमिटेड (नेपाल टेलिकम) को प्रबन्ध निर्देशक पदमा नियुक्त समेत भएकाे सुनिल पौडेलले अाफु पदमा रहदा पटक पटक गरी पदीय मर्यादा विपरीतका कार्यहरू गरी गैरकानूनी सम्पत्ति आर्जन गरेको भन्ने उजुरी निवेदन सम्बन्धमा अनुसन्धान भइ निजको आयतर्फ अंशहक वापत प्राप्त रकम, राष्ट्रिय सूचना प्रविधि केन्द्रबाट पारिश्रमिक बचत तथा अन्य सुबिधावापत प्राप्त रकम, नेपाल टेलिकमबाट पारिश्रमिक बचत, नेपाल टेलिकमबाट प्राप्त स्वदेश तथा विदेश भ्रमण भत्ता वापत प्राप्त रकम, बिभिन्न कम्पनीको शेयर बिक्री गर्दा प्राप्त रकम मध्ये खरिद गर्दा स्रोत खुलेको शेयर बिक्रीवापत प्राप्त रकम, सवारी साधन बिक्रीबाट प्राप्त रकम र स्वदेशमा रहेका बैङ्क निक्षेपवापत प्राप्त बैङ्क ब्याज रकमसमेत गरी जम्मा रु.1,19,24,846।47 (एक करोड उन्नाईस लाख चौबीस हजार आठ सय छयालीस पैसा सड्चालीस) आय आर्जन गरेको देखिन्छ।\r\n\r\nयसैगरी व्ययतर्फ राष्ट्रिय सुचना प्रवधि केन्द्रको कार्यकारी निर्देशक भएको अवधिमा आफैले टेण्डरहरुको कोटेशन (Quotation) बनाई योजनाबद्ध ढङ्गले आफैले चाहेको स्वदेशी आपूर्तिकर्ता WDN, OBCI, MAX, Next Gen Solution हरुसँग ठेक्का सम्झौता गर्ने र उक्त स्वदेशी आपूर्तिकर्ताहरुले सोही अवधिमा विदेशी आपूर्तिकर्ता Instasafe Inc र Bancotec Pte Ltd जस्ता कम्पनीहरुसँग साझेदारी गरी सूचना प्रविधिसँग सम्बन्धित सामानहरु स्वदेशमा आपूर्ति गर्ने गरेको र सो साझेदारी बापत विदेशी कम्पनीहरुले कमिशन बापत निजको सिङ्गापुर स्थित युनाईटेड ओभरसिज बैङ्कको बैङ्क खातामा प्राप्त रकम, सोही बैङ्कबाट ट्रान्सफर गरेको रकम, सहोदर दाई अनिल पौडेलमार्फत घरजग्गा लगायतका क्षेत्रमा लगानी गरेको रकम, विदेशमा गहना खरिद गर्दा खर्च गरेको रकम, विद्युतीय माध्यमको प्रयोग गरी अमिल्दो र उच्च जीवनस्तर यापनमा गरेको अन्य खर्च रकम, स्वदेशी बैङ्कहरुमा रहेको बैङ्क मौज्दात रकम, बिभिन्न कम्पनीहरुको शेयर खरिदमा खर्च गरेको रकम, सिङ्गापुरको प्रुण्डेसियल कम्पनीमा जीवन बीमाको प्रिमियमवापत तिरेको रकम, निजी तवरमा बिभिन्न देशमा भ्रमण गर्दा हवाई यात्रा/भ्रमण खर्च रकम, स्वदेशमा सुनचाँदी, हिरा/जवाहरात खरिद गर्दा खर्च गरेको रकम, स्वदेशमा बीमाको प्रिमियमवापत खर्च गरेको रकम, घरबहाल खर्चवापत तिरेको रकम, विदेशमा होटलबासवापत खर्च गरेको रकम, सवारी साधन खरिद गर्दा खर्च गरेको रकम, सवारी कर दस्तुर र नविकरणवापत खर्च गरेको रकम, नगद मौज्दात रहेको रकम र विदेशमा कपडा खरिद गर्दा खर्च गरेको रकम गरी जम्मा रु.24,94,71,171।04 (चौबीस करोड चौरानब्बे लाख एकहत्तर हजार एक सय एकहत्तर रुपैयाँ पैसा चार) खर्च तथा लगानी गरेको देखिन्छ।\r\n\r\nयसरी हेर्दा जाँचअवधिमा सिर्जित सम्पत्ति एवं खर्च तथा लगानीहरुमा गरिएको कुल खर्च र सोही अवधिको आयहरुको आय-व्यय प्रवाह विवरण (Income Expenditure Flow Chart) अनुसार जाँच अवधिमा स्रोत खुल्न आए बमोजिम सुनिल पौडेलको कुल वैध आय रु.१,१९,२४,८४६।४७ बाट निजले गरेको खर्च (व्यय) रु.24,94,71,171।04 घटाउँदा हुन आउने रु.२३,७५,४६,३२४।५७ (तेइस करोड पचहत्तर लाख छयालीस हजार तीन सय चौबीस रुपैया पैसा सन्ताउन्न) बराबरको खर्च तथा लगानी (सम्पत्ति) को बैधानिक स्रोत खुलेको नदेखिएकोले आय भन्दा व्यय बढी भै ऋणात्मक देखिंदा निज सुनिल पौडेलले आफू कार्यकारी प्रमुख भएका निकायहरुमा सामग्री आपूर्ति गर्ने स्वदेशी तथा विदेशी कम्पनीहरुसँग मोलमोलाई गरी ती कम्पनीहरुसँग गैरकानूनी कमिशन लिई विदेशी बैङ्कमा गैरकानूनी रुपमा बैङ्क खाता खोली रकम जम्मा गर्ने र त्यस्तो गैरकानूनी रकम स्वदेशमा र विदेशमा रहेका आफन्तमार्फत विभिन्न क्षेत्रमा लगानी गर्ने, आफ्नो हैसियतभन्दा बढी खर्च गरी अमिल्दो र अस्वाभाविक उच्च जीवनस्तर यापन गर्ने गरेकोसमेत प्रमाणित हुन आएकाले स्रोत नखुलेको रु.२३,७५,४६,३२४।५७ बराबरको सम्पत्ति निजले गैरकानूनी रुपमा आर्जन गरेको पुष्टि हुन आएको हुँदा निजलाई भ्रष्टाचार निवारण ऐन, २०५९ को दफा २० को उपदफा (१) बमोजिमको कसुरमा रु.२३,७५,४६,३२४।५७ बिगो कायम गरी भ्रष्टाचार निवारण ऐन, २०५९ को दफा २० को उपदफा (२) बमोजिम बिगो अनुसार कैद र बिगो बमोजिम जरिवानाको सजाय हुन।\r\n\r\nनिज सुनिल पौडेलले राष्ट्रिय सूचना प्रविधि केन्द्र र नेपाल दूरसञ्चार कम्पनी लिमिटेड (नेपाल टेलिकम) मा राष्ट्रसेवकको रुपमा कार्यरत रहँदा भ्रष्टाचार निवारण ऐन, २०५९ को दफा ५० बमोजिम पेस गरेको सम्पत्ति विवरणमा वास्तविक भए रहेको सम्पत्ति लुकाई/छिपाई झुट्टा विवरण पेस गरेको पुष्टि भएको हुँदा निजलाई भ्रष्टाचार निवारण ऐन, २०५९ को दफा १६ को उपदफा (२) बमोजिमको कसुरमा कैद र जरिवाना सजायसमेत हुन एवं निज नेपाल सरकार सञ्चार तथा सूचना प्रविधि मन्त्रालय, राष्ट्रिय सूचना प्रविधि विकास समिति, राष्ट्रिय सूचना प्रविधि केन्द्रको कार्यकारी निर्देशक र नेपाल दूरसञ्चार कम्पनी लिमिटेड (नेपाल टेलिकम) को प्रबन्ध निर्देशक समेतमा नियुक्त भएको पदाधिकारी रही भ्रष्टाचार निवारण ऐन, 2059 को दफा २४ बमोजिम थप सजाय तथा निजले गैरकानूनी रुपमा आर्जन गरेको सम्पत्ति भ्रष्टाचार निवारण ऐन, 2059 को दफा 20 को उपदफा (२), ऐ.ऐनको दफा ४७, अख्तियार दुरूपयोग अनुसन्धान आयोग ऐन, २०४८ को दफा २९ख. र पारस्परिक कानूनी सहायता ऐन, 2070 को दफा 12, कसूरजन्य सम्पत्ति तथा साधन (रोक्का, नियन्त्रण र जफत) ऐन, 2070 को दफा 10 र 11 समेतको प्रचलित कानून बमोजिम जफत/असुल उपर गरियाेस भनि अख्तियार दुरुप्रयाेग अनुसन्धानमा गरेकाे निवेदन ।\r\n\r\nसाथै राष्ट्रसेवक निज सुनिल पौडेलले सार्वजनिक सेवाको पदमा रहँदाका बखत अख्तियारको दुरुपयोग गरी गैरकानूनी रूपमा सम्पत्ति आर्जन गरेको स्रोत नखुल्ने सम्पत्तिबाट निजको सहोदर दाजु अनिल पौडेलका नाममा खरिद गरिएका घरजग्गा भ्रष्टाचार निवारण ऐन, 2059 को दफा ४७ तथा अख्तियार दुरूपयोग अनुसन्धान आयोग ऐन, २०४८ को दफा २९ख. बमोजिम जफत गर्ने प्रयोजनार्थ मात्र निज अनिल पौडेललाई प्रतिवादी कायम गरी आज विशेष अदालत, काठमाडौंमा आरोप-पत्र दायर गरिएको छ।\r\n\r\nअत निज सुनिल पाैडेल गैरकानूनी सम्पत्ति आर्जन (कमिशन/घुस लिई विदेशी बैंकमा रकम जम्मा गरी लगानी र खर्च गरेको । भ्रष्टाचार निवारण ऐन, २०५९ को अनुसार स्रोत नखुलेको रु. २३,७५,४६,३२४।५७ बराबरको सम्पत्ति आर्जन देखिएकाे, भ्रष्टाचार निवारण ऐन, २०५९ को दफा ५० बमोजिम पेस गरेको सम्पत्ति विवरणमा वास्तविक भए रहेको सम्पत्ति लुकाई/छिपाई झुट्टा विवरण पेस गरेको, राष्ट्रसेवकको पदको दुरुपयोग गरेकाे, टेन्डरमा अनियमितता गरी आफ्नो रोजेको कम्पनीहरूसँग मिलेमतोमा ठेक्का पास गरेको, विदेशी कम्पनी बाट कमिशन लिएर सिंगापुरको UOB बैंकमा खाता खोली रकम ट्रान्सफर गरेको, हैसियतभन्दा बढी खर्च गरी अमिल्दो उच्च जीवनस्तर यापन गरेको तथा अनिल पौडेलले गैरकानूनी रकम अाजर्न गर्न सहयाेग गरेकाे उनको नाममा घरजग्गा खरिद गरेकाले भ्रष्टाचार निवारण ऐन दफा ४७ र अख्तियार दुरुपयोग अनुसन्धान आयोग ऐन दफा २९ख. बमोजिम उक्त सम्पत्ति जफत गर्ने भन्ने अख्तियारकाे मागदाबी\r\n\r\n|  |  |  |  |  |  |  |\r\n| --- | --- | --- | --- | --- | --- | --- |\r\n| स.नं. | नाम / संस्था | पद तथा कार्यालय | बिगो रकम (रु.) | लागू दफा (भ्रष्टाचार निवारण ऐन, २०५९) | कसूरको स्वरूप | सजाय मागदाबी |\r\n| १ | सुनिल पौडेल | पूर्व कार्यकारी निर्देशक, राष्ट्रिय सूचना प्रविधि केन्द्र तथा प्रबन्ध निर्देशक, नेपाल टेलिकम | २३,७५,४६,३२४.५७ | दफा २०(१), २०(२), १६(२), २४, ५० | गैरकानूनी सम्पत्ति आर्जन, कमिशन लिने, विदेशी बैंकमा रकम जम्मा, झुट्टा सम्पत्ति विवरण पेश, पदको दुरुपयोग, टेन्डरमा मिलेमतो | बिगो बराबर जरिवाना, कैद सजाय, थप सजाय (दफा २४ अनुसार) |\r\n| २ | अनिल पौडेल | सहोदर दाजु (मध्यम व्यक्ति) | - | दफा ४७, अख्तियार ऐन २०४८ दफा २९ख | गैरकानूनी सम्पत्तिको लगानी/घरजग्गा खरिदमा सहयोग | सम्पत्ति जफत प्रयोजनार्थ प्रतिवादी कायम |","key_allegations":["राष्ट्रिय सूचना प्रविधि केन्द्र (कार्यकारी निर्देशक) र नेपाल टेलिकम (प्रबन्ध निर्देशक)  सुनिल पाैडेलकाे जाँच अवधिमा अनुसन्धान गरी हेर्दा  वैध आय: १,१९,२४,८४६।४७  मात्र हुनुपर्नेमा कुल सम्पति   रु. २४,९४,७१,१७१।०४ रहेकाे र उक्त रकम मध्ये  रु. २३,७५,४६,३२४।५७ रकम (आयभन्दा २० गुणा बढी व्यय) स्रााेत नखुलेकाे रकम रहेकाे ।","राष्ट्रिय सूचना प्रविधि केन्द्र (कार्यकारी निर्देशक) र नेपाल टेलिकम (प्रबन्ध निर्देशक) मा रहँदा आफैले टेन्डरको कोटेशन बनाई आफ्नो रोजेको स्वदेशी आपूर्तिकर्ता (WDN, OBCI, MAX, Next Gen Solution) सँग ठेक्का सम्झौता गरि उक्त स्वदेशी कम्पनीहरूले विदेशी आपूर्तिकर्ता (Instasafe Inc र Banc tec Pte Ltd) सँग साझेदारी गरी सूचना प्रविधि सामान आपूर्ति गरेको र सो साझेदारीबापत विदेशी कम्पनीहरूले कमिशन दिएको।","सो कमिशन सिंगापुरको United Overseas Bank (UOB) मा निजको खातामा जम्मा भएको, ट्रान्सफर भएको र सहोदर दाजु अनिल पौडेलमार्फत घरजग्गा, अन्य लगानी तथा उच्च जीवनस्तरमा खर्च गरेको।"],"timeline":[{"date":"2004-06-02","title":"राष्ट्रिय सूचना प्रविधि केन्द्र, सिंहदरबारमा प्रशासकिय अधिकृतको पदमा करार सेवामा नियुक्त ।","date_bs":"2061-02-20","description":""},{"date":"2008-06-26","title":"२०६५/०३/१२ मा राष्ट्रिय सूचना प्रविधि केन्द्र, कम्प्युटर इन्जिनियर पदमा करारमा नियुक्त भइ मिति २०७५/०४/२० गते  सम्म कार्यरत रहेको","date_bs":"2065-03-12","description":""},{"date":"2018-07-15","title":"राष्ट्रिय सूचना प्रविधि केन्द्र, सिंहदरबारमा उपकार्यकारी निर्देशक पदमा करारमा नियुक्त भइ मिति २०७५/०४/२० सम्म कार्यरत रहेको,","date_bs":"2075-03-31","description":""},{"date":"2018-08-06","title":"राष्ट्रिय सूचना प्रविधि केन्द्र, सिंहदरबारमा केन्द्रय कार्यकारी निर्देशक पदमा करारमा नियुक्त भएकाे","date_bs":"2075-04-21","description":""},{"date":"2022-04-07","title":"नेपाल टेलिकम लिमिटेड (सञ्चार संस्था) का प्रबन्ध निर्देशक पदमा नियुक्त भई कार्यरत रहेकाे ।","date_bs":"2078-12-24","description":""},{"date":"2024-04-19","title":"गैरकानूनी सम्पत्ति आर्जन गरेको भन्ने उजुरी निवेदन परेकाे र साे सम्बन्धमा अनुसन्धान   निजको आयतर्फ अत्याधिक विदृि देखिएकाे ठहर गर्दै निज विरूद्ध अख्तियारले विशेष अदालतमा उजुरी चलाउने निर्णय ।","date_bs":"2081-01-07","description":""},{"date":"2024-04-21","title":"गैरकानूनी सम्पत्ति आर्जन गरेको अभियाेग लगाइ अख्तियार दुरुप्रयाेग अनुसन्धान अायाेगकाे तत्कालीन  राष्ट्रिय सूचना प्रविधि केन्द्र कार्यकारी निर्देशक तथा  नेपाल टेलिकम प्रबन्ध निर्देशक सुनिल पाैडेल र उनका दाजु अनिल पौडेल विरूद्ध विशेष अदालतमा अभियाेग दर्ता ।","date_bs":"2081-01-09","description":""},{"date":"2026-02-24","title":"हाल सम्म अाइ पुगि विशेष अदालतकाे प्रगती  विवरण हेर्दा","date_bs":"2082-11-12","description":"मिति २०८२/०१/१२ गते सुनिल पौडेललाई थुनामा राख्ने थुनछेक आदेश, २०८२/०६/०८ बहस नाेट पेश गर्ने अादेश, २०८२/०९/२२ गते प्रतिवादी झिकाउने आदेश गर्दै हाल सम्म अाइ पुग्दा वुझ्ने अादेश सम्म भएकाे देखिन्छ ।"}],"evidence":[{"source_id":"source:20260325:97ea4a55","description":"मिति २०८१ वैशाख महिनाकाे ९ गते जारी गरिएकाे  प्रेश विज्ञप्ती"},{"source_id":"source:20260304:13cf884f","description":"मिति २०७८/१२/२५ मा नेपाल दुरसञ्चार कम्पनी लिमिटेड (नेपाल टेलिकम) को प्रबन्ध निर्देशक पदमा सुनिल पौडेल नियुक्त भएकाे"},{"source_id":"source:20260325:ae8de39b","description":"मिति २०८१ साल वैशाख ९ गते सम्पादन गरिएकाे २३ करोड ७५ लाख बिगो दाबी गर्दै सुनिल पौडेलविरुद्ध अर्को भ्रष्टाचार मुद्दा दायर शिर्षककाे समाचार"},{"source_id":"source:20260331:600aa374","description":"."}],"notes":"Case drafted by Niroj Aryal. First published on April 1, 2026.","court_cases":[],"missing_details":"मुद्दाको विश्लेषणमा प्राप्त नभएको स्रोतहरू:-\r\n\r\nक) अभियाेग पत्र  \r\n\r\nख) वहस नाेट तथा प्रतिवादीबाट अदालतमा प्रस्तुत गरिएका अन्य सवुत तथा प्रमाणहरू  \r\n\r\nग) प्रस्तुत मुद्दासँग सम्बद्ध थप आधार र प्रमाण पुष्टि गर्ने प्रमाणका स्रोतहरु  \r\n\r\nअन्य आवश्यक स्रोतहरू","bigo":null,"versionInfo":{},"created_at":"2026-03-25T13:04:41.363746+05:45","updated_at":"2026-05-19T17:19:15.714241+05:45"},{"id":212,"case_id":"case-86227453885e","slug":"case-081-cr-0080-82b7d966","case_type":"CORRUPTION","state":"PUBLISHED","title":"मधेश प्रदेश स्वास्थ्य उपकरण खरिद भ्रष्टाचार मुद्दा (081-CR-0080)","short_description":"","thumbnail_url":"https://shilapaper.com/wp-content/uploads/2025/04/Health_lab-Janakpurdham-currption-Cover-1024x500-1.jpg","banner_url":"https://shilapaper.com/wp-content/uploads/2025/04/Health_lab-Janakpurdham-currption-Cover-1024x500-1.jpg","case_start_date":"2025-04-27","case_end_date":"2026-02-25","entities":[{"id":3624,"nes_id":"entity:person/ram-udgar-yadav","display_name":"राम उदगार यादव","type":"accused","notes":""},{"id":3624,"nes_id":"entity:person/ram-udgar-yadav","display_name":"राम उदगार यादव","type":"related","notes":""},{"id":3622,"nes_id":"entity:person/umesh-chaudhary","display_name":"उमेश चौधरी","type":"accused","notes":""},{"id":3622,"nes_id":"entity:person/umesh-chaudhary","display_name":"उमेश चौधरी","type":"related","notes":""},{"id":2149,"nes_id":null,"display_name":"जनकपुरधाम","type":"location","notes":""},{"id":2134,"nes_id":"entity:person/shravana-kumaara-mishra","display_name":"श्रवण कुमार मिश्र","type":"related","notes":""},{"id":2139,"nes_id":"entity:person/amara-deepa-mahato","display_name":"अमर दीप महतो","type":"related","notes":""},{"id":2141,"nes_id":"entity:person/karmashila-prasaada-gopa","display_name":"कर्मशिल प्रसाद गोप","type":"related","notes":""},{"id":2142,"nes_id":"entity:person/gunaananda-prasaada-saaha","display_name":"गुणानन्द प्रसाद साह","type":"related","notes":""},{"id":2147,"nes_id":"entity:person/mana-mohana-mishra","display_name":"मन मोहन मिश्र","type":"related","notes":""},{"id":2152,"nes_id":"entity:person/anila-saaha","display_name":"अनिल साह","type":"related","notes":""},{"id":2153,"nes_id":"entity:person/sebhena-hilsa-praa-lee","display_name":"सेभेन हिल्स प्रा.ली","type":"related","notes":""},{"id":2134,"nes_id":"entity:person/shravana-kumaara-mishra","display_name":"श्रवण कुमार मिश्र","type":"accused","notes":""},{"id":2139,"nes_id":"entity:person/amara-deepa-mahato","display_name":"अमर दीप महतो","type":"accused","notes":""},{"id":2141,"nes_id":"entity:person/karmashila-prasaada-gopa","display_name":"कर्मशिल प्रसाद गोप","type":"accused","notes":""},{"id":2142,"nes_id":"entity:person/gunaananda-prasaada-saaha","display_name":"गुणानन्द प्रसाद साह","type":"accused","notes":""},{"id":2147,"nes_id":"entity:person/mana-mohana-mishra","display_name":"मन मोहन मिश्र","type":"accused","notes":""},{"id":2152,"nes_id":"entity:person/anila-saaha","display_name":"अनिल साह","type":"accused","notes":""},{"id":2153,"nes_id":"entity:person/sebhena-hilsa-praa-lee","display_name":"सेभेन हिल्स प्रा.ली","type":"accused","notes":""}],"tags":["nphl","Public Procurement"],"description":"प्रस्तुत मुद्दामा मधेस प्रदेश, धनुषा जिल्ला, प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामले आ.व. २०७८/७९ मा मधेस प्रदेशका ६४ वटा स्थानीय तहमा जनस्वास्थ्य प्रयोगशाला (निदान केन्द्र) स्थापनाको लागि Contract No: PPHL2/G/NCB/05/2078-79 अन्तर्गत उपकरण, IT Infrastructure, Software तथा Furniture खरिद गरेको देखिन्छ।\r\n\r\nखरिद प्रक्रियामा सार्वजनिक खरिद नियमावली, २०६४ बमोजिम आवश्यक पर्ने गुरुयोजना तयार गरिएको नभएको, पूर्व सम्भाव्यता अध्ययन गरिएको नभएको, लाभ–लागत विश्लेषण तथा उपयुक्त खरिद विधिको पहिचान गरिएको नभएको, साथै, स्थानीय तहको जनसंख्या, बिरामीको चाप तथा उपकरणको क्षमता विश्लेषण नगरी खरिद गरिएको, उपकरण जडान हुने स्थान स्पष्ट गरिएको नभएको र आपूर्तिकर्ता सेभेन हिल्स प्रा.लि., सिनामंगल, काठमाडौँसँग मिलेमतो गरी स्वीकृत स्पेसिफिकेशनभन्दा कम गुणस्तरका सामग्रीलाई मापदण्ड अनुसार रहेको भनी स्वीकार गरिएको पाइएको थियो । गलत Post Delivery Inspection (PDI) प्रतिवेदन तयार गरी रु. ५,०१,९०,०८०।– भुक्तानी गरिएको र यसबाट सरकारी सम्पत्तिमा हानि पुर्‍याइएको भनी दावी गरिएको थियो।\r\nयस मुद्दामा अख्तियारले तत्कालीन निर्देशक डा. श्रवणकुमार मिश्र, वरिष्ठ ल्याब टेक्निसियन गुणानन्द प्रसाद साह, वरिष्ठ ल्याब अधिकृत उमेश चौधरी, लेखा अधिकृत अमरदीप महतो, ल्याब असिस्टेन्ट कर्मशील प्रसाद गोप, मेडिकल ल्याब टेक्नोलोजिष्ट मनमोहन मिश्र, ल्याब टेक्निसियन निरीक्षक रामउदगार यादव तथा सेभेन हिल्स प्रा.लि. र सञ्चालक अनिल शाह समेतलाई प्रतिवादी बनाइएको छ। उनीहरू विरुद्ध भ्रष्टाचार निवारण ऐन, २०५९ को दफा ८(१), दफा १९(२), दफा २२ तथा दफा २४ बमोजिम कसूरमा कैद, जरिवाना तथा बिगो असुलउपरको माग दाबी लिई विशेष अदालत, काठमाडौंमा आरोपपत्र दायर गरेको थियो।\r\n\r\nमिति २०८२-०१-१५ मा दर्ता भएको मुद्दा मिति २०८२-११-१३ मा विशेष अदालतले लामो सुनुवाइपछि विशेष अदालतका अध्यक्ष सुदर्शन देव भट्ट तथा न्यायाधीशहरू हेमन्त रावल र डिल्लीरत्न श्रेष्ठको इजलासले आंशिक ठहर फैसला गरेको थियो। यद्यपि विशेष अदालतको फैसलाको पूर्ण पाठ भने सार्वजनिक भैसकेको छैन\r\n\r\n<br>\r\nRelated Cases\r\n\r\n* 081-CR-0079\r\n\r\n\r\n* 081-CR-0081\r\n\r\n\r\n* 081-CR-0082","key_allegations":["जिल्ला धनुषा, प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामले आर्थिक वर्ष २०७८/७९ मा आह्वान गरेको ठेक्का नं. PPHL2/G/NCB/05/2078-79 अन्तर्गत Pathology Lab स्थापना गर्न आवश्यक उपकरण, आईटी पूर्वाधार, सफ्टवेयर तथा फर्निचर खरिद गर्दा प्रचलित सार्वजनिक खरिद ऐन, नियमावली तथा सम्बन्धित कानुन विपरीत कार्य गरेको भन्ने समेतको अभियोग।","खरिद प्रक्रियामा आवश्यक पूर्वाधार, सम्भाव्यता अध्ययन, लाभ–लागत विश्लेषण र उपयुक्त खरिद विधि अध्ययन नगरी बजेट माग गरी खरिद अगाडि बढाइएको।","एउटै शीर्षकको खरिदलाई टुक्र्याएर खरिद गरिएको, उपकरण जडान हुने पालिकाको जनसंख्या तथा बिरामीको चापको विश्लेषण नगरी कार्य गरिएको पाइएको।","अपूर्तिकर्ता सेभेन हिल्स प्रा.लि. सँग मिलेमतो गरी स्वीकृत स्पेसिफिकेशन भन्दा फरक र कम गुणस्तरका सामग्री आपूर्ति गरिएको र स्पेसिफिकेशनअनुसारकै रहेको भनी गलत PDI प्रतिवेदन पेश गरी रु. ५,०१,९०,०८०।– भुक्तानी गरिएको।"],"timeline":[{"date":"2021-11-18","title":"प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामबाट बजेट माग","date_bs":"2078-08-02","description":"प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामबाट प्रदेश निदान केन्द्र सञ्चालन गर्न १३६ पालिकाको लागि रु. ५८.१४.१२.२४०।- रकमको बजेट मिति २०७८।०८।०२ मा माग भएको ।"},{"date":"2022-03-09","title":"सामाजिक विकास मन्त्रालय, मधेश प्रदेश, जनकपुरबाटबजेटको स्रोत सुनिश्चितताको लागि अर्थ मन्त्रालयमा माग","date_bs":"2078-11-25","description":"मन्त्रिस्तरिय निर्णयानुसार ६४ वटा पालिकाहरुमा प्रदेश निदान केन्द्र सञ्चालन गर्न रु. २६,३६,८३,२००।- रकमको थप बजेटको स्रोत सुनिश्चितताको लागि अर्थ मन्त्रालयमा मा माग भएको।"},{"date":"2022-06-02","title":"प्रदेश सरकारबाट रकम स्वीकृत","date_bs":"2079-02-19","description":"मधेश प्रदेश सरकार, मन्त्रिपरिषद्‌को निर्णयानुसार ६४ वटा पालिकाहरुमा प्रदेश निदान केन्द्र संचालन गर्न रु. २५,३८,५३.१२०।- रकम स्वीकृत भएको।"},{"date":"2022-06-02","title":"स्पेशिफिकेशन तथा लागत अनुमान स्वीकृत","date_bs":"2079-02-19","description":"जितेन्द्र कुमार साह (माइक्रोबाइलोजिस्ट), अमरेन्द्र कुमार (माइक्रोबाइलोजिस्ट), रमेश कुमार मण्डल (ल्याब असिस्टेन्ट) र स्वीकृत गर्नेः निर्देशक डा. श्रवण कुमार मिश्रबाट स्पेशिफिकेशन तयार भई सोही मिति मा डा. श्रवण कुमार मिश्रबाट लागत अनुमान रु. ५,२८,६५,९२०।- स्वीकृत भएको।"},{"date":"2022-06-06","title":"बोलपत्र पेश गर्ने सूचना","date_bs":"2079-02-23","description":"सार्वजनिक खरिद ऐनको दफा ६६ र नियमावली २०६४ को नियम १४५ बमोजिम विशेष परिस्थितिको खरिद गर्न मेसिनरी औजार तथा सफ्टवेयर र फर्निचर तथा फिक्चर्स खरिदको लागि रू. ५,२८,६५,९२०।- लागत अनुमानको विद्युतिय बोलपत्रको १५ दिनको सूचना आव्हान गरी E-Bidding गर्ने निर्णय स्वीकृत भई ठेक्का नं. PPHL2/G/NCB-05/2078-79 को लागि सुचना प्रकाशन भएको।"},{"date":"2022-06-21","title":"बोलपत्र प्रस्ताव पेस","date_bs":"2079-03-07","description":"१ (एक) वटा फर्म सेभेन हिल्स  प्रा.लि.. काठमाडौँले मात्र ले प्रस्ताव गरेको।"},{"date":"2022-06-22","title":"प्राविधिक मुल्याङ्कन उप-समितिको प्रतिवेदन","date_bs":"2079-03-08","description":"प्राविधिक मूल्याङ्कन उप-समिति (जितेन्द्र कुमार साह (माइक्रोबाइलोजिस्ट), अमरेन्द्र कुमार मिश्र (माइक्रोबाइलोजिस्ट) र रमेश कुमार मण्डल (ल्याब असिस्टेन्ट) ले बोलपत्र प्रस्तावदाता श्री सेभेन हिल्स प्राइभेट लिमिटेड., काठमाडौँले पेश गरेको कागजातहरु ठेक्का सम्बन्धी कागजातहरुसँग पूर्ण रुपमा मेल खाएकोले अगाडीको प्रक्रियाको लागि सिफारिस गरेको।"},{"date":"2022-06-23","title":"मूल्याङ्कन समितिको निर्णय","date_bs":"2079-03-09","description":"बोलपत्र मूल्याङ्कन समिति (उमेश चौधरी (ब.ल्या.अ.), अमर दीप महतो (लेखा अधिकृत), कर्मशिल प्रसाद गोप (ल्या.अ.) र गुणानन्द प्रसाद साह (ब.ल्या.टे.नि.)) ले ठेक्का नं. PPHL2/G/NCB-04/2078-79 को लागि पेश हुन आएको बोलपत्रको Responsive Chart तयार गरी अध्ययन गर्दा श्री सेभेन हिल्स प्राइभेट लिमिटेड., काठमाडौँले पेश गरेको बोलपत्र न्यूनतम मूल्याङ्कित सारभूतरुपमा रुपमा प्रभावग्राही देखिएकोले निजको कबोल अंक रू.५ ,०१,९०,०८०।- (मु.अ.कर सहित) को बोलपत्र स्वीकृतिको सिफारिस गरेको।"},{"date":"2022-07-05","title":"सम्झौता र कार्यदिशा","date_bs":"2079-03-21","description":"प्रयोगशालाको तर्फबाट निर्देशक डा. श्रवण कुमार मिश्र र सेभेन हिल्स प्रा.लि., काठमाडौंको तर्फबाट चेयरम्यान अनिल साहद्वारा समझौतामा हस्ताक्षर भएको।"},{"date":"2022-07-07","title":"Post Delivery Inspection","date_bs":"2079-03-23","description":"ब.ल्या.अ. उमेश चौधरी र निर्देशक डा. श्रवण कुमार मिश्रले \"The equipment is delivered at PPHL Site\" भनी प्रतिवेदन पेश गरेको।"},{"date":"2022-07-07","title":"प्रयोगशाला मुल्याङ्कन समितिको निर्णय","date_bs":"2079-03-23","description":"प्रयोगशाला मुल्याङ्कन समिति (ब.ल्या.अ. उमेश चौधरी, ले.अ. अमर दीप महतो, ल्या. अ. कर्मशील प्रसाद गोप, ब.ल्या.टे.नि. गुणानन्द प्रसाद साह र आमन्त्रित निर्देशक डा. श्रवण कुमार मिश्र) ले ठेक्का नं. PPHL2/G/NCB/05/2078-79, Supply, Delivery and Installation of Equipment, IT infrastructures, Software, Furniture for establishment of Pathology Lab in Municipality को लागि सेभेन हिल्स प्रा.लि., काठमाडौंले प्रयोगशालामा आपूर्ती गरेको मालसामानहरू मध्येबाट Random Sampling गरी Post delivery Inspection प्रतिवेदन अनुसार Verification गर्दा नमुनाहरू बोलपत्रमा माग भए बमोजिम देखिएको हुँदा अगाडी प्रक्रियाको लागि सिफारिस गर्ने निर्णय गरेको।"},{"date":"2022-07-07","title":"खरिद आदेश र दाखिला प्रतिवेदन","date_bs":"2079-03-23","description":"कार्यालयबाट मिति २०७९।०३।२३ मा खरिद आदेश र दाखिला प्रतिवेदन जिन्सी प्रमुख कर्मशिल प्रसाद गोप (ल्या.अ.) ले तयार गरी निर्देशक डा. श्रवण कुमार मिश्रले स्वीकृत गरेको।"},{"date":"2022-07-09","title":"श्री सेभेन हिल्स प्रा.लि., काठमाडौँलाई मेशिनरी औजार, फर्निचर तथा सफ्टवेयर खरिदको भुक्तानी","date_bs":"2079-03-25","description":"गो.भौ.नं. ४५ मिति २०७९।०३।२५ बाट रु. ४,८५,६२,८८०।- (कर बाहेक) भुक्तानी भएको।"},{"date":"2022-12-04","title":"महालेखापरीक्षकको निरीक्षण प्रतिवेदन","date_bs":"2079-08-18","description":"प्रदेश निदान केन्द्र स्थापना भएका स्थानीय तहको दाखिला प्रतिवेदन हेर्दा मिति 2079/08/18 गते पूर्व कुनै पनि स्थानीय तहमा उक्त उपकरणहरू दाखिला भएको नपाइएको भनी महालेखापरीक्षकको प्रतिवेदनले पुष्टी गरेको ।"},{"date":"2023-01-19","title":"अख्तियारको स्थलगत अनुगमन प्रतिवेदन","date_bs":"2079-10-05","description":"स्थलगत नापजाँचबाट प्रयोगशालामा आपूर्ति गरिएको सामग्रीहरू स्वीकृत स्पेसिफिकेशनअनुसार नभएको देखिएको छ। Colorimeter कबोल गरिएको ब्राण्डअनुसार जडान गरिएको नभई फरक–फरक ब्राण्ड प्रयोग गरिएको पाइिएको छ र डिस्प्ले विशेषता पनि नमिलेको देखिएको छ। ISO सम्बन्धी प्रमाणिकरण पुष्टि भएको देखिएको छैन। Centrifuge मा ब्राण्ड तथा मोडेल उल्लेख गरिएको नभएको, क्याटलग बनावटी रूपमा तयार गरिएको जस्तो देखिएको र प्राविधिक मापदण्ड अनुरूप रहेको नभएको पाइिएको छ। Table, Chair तथा Storage Rack कबोलअनुसार उपलब्ध गरिएको नभएको, आकार र बनावटमा फरक परेको तथा प्रयोगयोग्य अवस्थामा रहेको नभएको देखिएको छ। Refrigerator प्रयोगशाला प्रयोजनअनुसार प्रदान गरिएको नभई घरेलु प्रयोगको रहेको, आवश्यक प्रविधिक सुविधा समावेश गरिएको नभएको पाइिएको छ। समग्रमा, आपूर्ति गरिएको सामग्री गुणस्तरहीन रहेको र स्वीकृत मापदण्डअनुसार मिलेको नभएको निष्कर्ष निकालिएको छ।आदि ।"},{"date":"2023-03-19","title":"अख्तियारको विस्तृत स्थलगत प्रतिवेदन","date_bs":"2079-12-05","description":"स्थलगत निरीक्षणबाट विभिन्न जिल्लाका प्रयोगशालाहरूमा आपूर्ति गरिएका सामग्रीहरू प्रभावकारी रूपमा प्रयोगमा आएको नभएको देखिएको छ। धनुषा र पर्साका केही स्थानीय तहहरूमा सामग्री जडान गरिएको नभई थन्क्याई राखिएको पाइिएको छ भने कतिपय प्रयोगशालाहरू सञ्चालनमा नरहेको अवस्था भेटिएको छ। रौतहट, पर्सा, बारा, सप्तरी, सिरहा र सर्लाही जिल्लाका धेरै प्रयोगशालाहरूमा उपकरणहरू प्रयोग गरिएको नभई जगेडामा राखिएको, प्राविधिक समस्या तथा जनशक्ति अभावका कारण सेवा प्रवाह भएको नभएको देखिएको छ। कतिपय स्थानमा आवश्यक पूर्वाधार जस्तै अर्थिङ्ग तथा कम्प्युटर प्रणाली जडान गरिएको नभएको र भएका उपकरणहरू बिग्रिएको अवस्थामा रहेको पाइिएको छ। Dolphin LIS प्रणाली प्रयोग गरिएको नभएको वा अद्यावधिक गरिएको नभएको देखिएको छ। समग्रमा, आवश्यकता पहिचान नगरी खरिद प्रक्रिया सम्पन्न गरिएको, उपकरणहरूको उपयोगिता सुनिश्चित गरिएको नभएको तथा सार्वजनिक सम्पत्तिको हानिनोक्सानी भएको निष्कर्ष निकालिएको छ।आदि ।"},{"date":"2025-04-27","title":"अख्तियार दुरुपयोग अनुसन्धान आयोगको प्रेस विज्ञप्ति","date_bs":"2082-01-14","description":"जिल्ला धनुषा, प्रदेश जनस्वास्थ्य प्रयोगशाला, जनकपुरधामले आर्थिक वर्ष २०७८/७९ मा आह्वान गरेको ठेक्का नं. PPHL2/G/NCB/05/2078-79 अन्तर्गत Pathology Lab स्थापना गर्न आवश्यक उपकरण, आईटी पूर्वाधार, सफ्टवेयर तथा फर्निचर खरिद गर्दा प्रचलित सार्वजनिक खरिद ऐन, नियमावली तथा सम्बन्धित कानुन विपरीत कार्य गरेको भन्ने समेतको अभियोग लगाएको सूचना सहितको प्रेस विज्ञप्ति ।"},{"date":"2026-02-25","title":"फैसला","date_bs":"2082-11-13","description":"विशेष अदालतका अध्यक्ष सुदर्शनदेव भट्ट तथा न्यायाधीशहरू हेमन्त रावल र डिल्लीरत्न श्रेष्ठको इजलासले आंशिक ठहर फैसला गरेको।"}],"evidence":[{"source_id":"source:20260323:e4f2afd8","description":"CIAA"},{"source_id":"source:20260323:72551c0c","description":"Office of Attorney Genera"},{"source_id":"source:20260320:d94b7d33","description":"Nepal Law Commission"},{"source_id":"source:20260320:d94b7d33","description":"Nepal Law Commission"},{"source_id":"source:20260320:44bd104b","description":"Nepal Law Commission"},{"source_id":"source:20260321:a19b89d0","description":"Office of Auditor General"},{"source_id":"source:20260320:032a1cb9","description":"Onlinekhabar — Article published on Baisakh 14, 2082 (April 27, 2025)"},{"source_id":"source:20260323:40bb07d0","description":"Sourya Khabar — Article published on April 28, 2025 (Baisakh 15, 2082)"},{"source_id":"source:20260320:28e0b32b","description":"Ukeraa — Article published on Baisakh 14, 2082 (April 27, 2025)"}],"notes":"Case drafted by Rujit Kafle.. Case first published on March 30, 2026.\r\n\r\nCase updated on 04/01/2026 with note: ⁠Minor corrections.","court_cases":["special:081-CR-0080"],"missing_details":"मुद्दाको विश्लेषणमा प्राप्त नभएको स्रोतहरू:-\r\n\r\nक) प्रतिवादीहरूले अदालतमा गरेको बयानको ब्याहोरा\r\n\r\nख) प्रस्तुत मुद्दासँग सम्बद्ध थप आधार र प्रमाण पुष्टि गर्ने प्रमाणिक स्रोत\r\n\r\nग) विशेष अदालतको फैसलाको प्रतिलिपि\r\n\r\nघ) अन्य आवश्यक स्रोतहरू।","bigo":null,"versionInfo":{},"created_at":"2026-03-23T17:11:37.737477+05:45","updated_at":"2026-05-20T15:15:58.841762+05:45"}]},"dataUpdateCount":1,"dataUpdatedAt":1781094635494,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["cases",{"page":1}],"queryHash":"[\"cases\",{\"page\":1}]"}]}</script>
